<div id="<%= dom_id(comment, :modal) %>" class="mb-3">
  <div class="d-flex justify-content-between align-items-start gap-2">
    <div>
      <strong>
        <%= link_to comment.author.username,
              user_path(comment.author.username),
              class: "text-dark text-decoration-none" %>
      </strong>

      <%= comment.body %>

      <div class="small text-muted">
        <%= time_ago_in_words(comment.created_at) %> ago
      </div>
    </div>

    <% if current_user == comment.author %>
      <%= form_with url: comment_path(comment, format: :turbo_stream),
      method: :delete,
      class: "m-0",
      data: { turbo: true } do %>
        <%= hidden_field_tag :expanded, false %>

        <button type="submit"
          class="btn btn-sm btn-link text-danger text-decoration-none p-0">
          <i class="fa-solid fa-trash"></i>
        </button>
      <% end %>
    <% end %>
  </div>
</div>
