<% content_for :title, "Network" %>

<% owner_friends = (current_user.owner_friends + current_user.friended_by_users).uniq %>
<% received_owner_requests = current_user.pending_received_user_friendships %>
<% sent_owner_requests = current_user.sent_user_friendships.pending %>
<% owner_request_count = received_owner_requests.count + sent_owner_requests.count %>

<% received_pet_requests = current_user.pets.flat_map { |pet| pet.received_pet_friendships.pending } %>
<% sent_pet_requests = current_user.pets.flat_map { |pet| pet.sent_pet_friendships.pending } %>
<% pet_request_count = received_pet_requests.count + sent_pet_requests.count %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Network</h1>
</div>

<ul class="nav nav-pills mb-4" id="network-tabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active"
            id="owner-tab"
            data-bs-toggle="tab"
            data-bs-target="#owner-network"
            type="button"
            role="tab">
      Owner friends
      <span class="badge text-bg-secondary"><%= owner_friends.count %></span>
    </button>
  </li>

  <li class="nav-item" role="presentation">
    <button class="nav-link"
            id="pet-tab"
            data-bs-toggle="tab"
            data-bs-target="#pet-network"
            type="button"
            role="tab">
      Pet friends
      <span class="badge text-bg-secondary"><%= current_user.pets.count %></span>
    </button>
  </li>
</ul>

<div class="tab-content">
  <div class="tab-pane fade show active" id="owner-network" role="tabpanel">
    <div class="card mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0">Owner friends</h5>

          <button class="btn btn-outline-primary btn-sm"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#owner-requests">
            Requests
            <span class="badge text-bg-primary"><%= owner_request_count %></span>
          </button>
        </div>

        <div class="collapse mb-3" id="owner-requests">
          <div class="border rounded p-3">
            <h6>Pending requests</h6>

            <% received_owner_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                <div>
                  <%= link_to friendship.requester.username,
                        user_path(friendship.requester.username),
                        class: "text-decoration-none fw-bold" %>
                  wants to be your friend.
                </div>

                <div class="d-flex gap-2">
                  <%= button_to "Accept",
                        user_friendship_path(friendship),
                        method: :patch,
                        params: { user_friendship: { status: "accepted" } },
                        class: "btn btn-primary btn-sm" %>

                  <%= button_to "Decline",
                        user_friendship_path(friendship),
                        method: :patch,
                        params: { user_friendship: { status: "declined" } },
                        class: "btn btn-outline-secondary btn-sm" %>
                </div>
              </div>
            <% end %>

            <% sent_owner_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                <div>
                  Requested
                  <%= link_to friendship.receiver.username,
                        user_path(friendship.receiver.username),
                        class: "text-decoration-none fw-bold" %>
                </div>

                <%= button_to "Cancel",
                      user_friendship_path(friendship),
                      method: :delete,
                      class: "btn btn-outline-danger btn-sm" %>
              </div>
            <% end %>

            <% if owner_request_count.zero? %>
              <div class="text-muted">No owner requests.</div>
            <% end %>
          </div>
        </div>

        <div class="list-group list-group-flush">
          <% owner_friends.each do |user| %>
            <%= link_to user_path(user.username),
                  class: "list-group-item list-group-item-action px-0" do %>
              <div class="d-flex align-items-center">
                <% if user.avatar_image.attached? %>
                  <%= image_tag user.avatar_image,
                        class: "rounded-circle me-3",
                        style: "width: 48px; height: 48px; object-fit: cover;" %>
                <% else %>
                  <div class="rounded-circle border bg-light d-flex align-items-center justify-content-center me-3"
                       style="width: 48px; height: 48px;">
                    <%= user.username.first.upcase %>
                  </div>
                <% end %>

                <div>
                  <div class="fw-bold"><%= user.username %></div>
                  <div class="text-muted small"><%= user.display_name %></div>
                </div>
              </div>
            <% end %>
          <% end %>

          <% if owner_friends.empty? %>
            <div class="text-muted">No owner friends yet.</div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="tab-pane fade" id="pet-network" role="tabpanel">
    <div class="card mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0">Pet friends</h5>

          <button class="btn btn-outline-primary btn-sm"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#pet-requests">
            Requests
            <span class="badge text-bg-primary"><%= pet_request_count %></span>
          </button>
        </div>

        <div class="collapse mb-3" id="pet-requests">
          <div class="border rounded p-3">
            <h6>Pending pet requests</h6>

            <% received_pet_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                <div>
                  <%= link_to friendship.requester_pet.name,
                        pet_path(friendship.requester_pet),
                        class: "text-decoration-none fw-bold" %>
                  wants to be friends with
                  <%= link_to friendship.receiver_pet.name,
                        pet_path(friendship.receiver_pet),
                        class: "text-decoration-none fw-bold" %>.
                </div>

                <div class="d-flex gap-2">
                  <%= button_to "Accept",
                        pet_friendship_path(friendship),
                        method: :patch,
                        params: { pet_friendship: { status: "accepted" } },
                        class: "btn btn-primary btn-sm" %>

                  <%= button_to "Decline",
                        pet_friendship_path(friendship),
                        method: :patch,
                        params: { pet_friendship: { status: "declined" } },
                        class: "btn btn-outline-secondary btn-sm" %>
                </div>
              </div>
            <% end %>

            <% sent_pet_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                <div>
                  <%= friendship.requester_pet.name %> requested
                  <%= link_to friendship.receiver_pet.name,
                        pet_path(friendship.receiver_pet),
                        class: "text-decoration-none fw-bold" %>
                </div>

                <%= button_to "Cancel",
                      pet_friendship_path(friendship),
                      method: :delete,
                      class: "btn btn-outline-danger btn-sm" %>
              </div>
            <% end %>

            <% if pet_request_count.zero? %>
              <div class="text-muted">No pet requests.</div>
            <% end %>
          </div>
        </div>

        <% current_user.pets.each do |pet| %>
          <div class="mb-4">
            <h6 class="mb-2">
              <%= link_to pet.name, pet_path(pet), class: "text-decoration-none" %>
            </h6>

            <div class="list-group list-group-flush">
              <% (pet.pet_friends + pet.friended_by_pets).uniq.each do |friend_pet| %>
                <%= link_to pet_path(friend_pet),
                      class: "list-group-item list-group-item-action px-0" do %>
                  <div class="d-flex align-items-center">
                    <% if friend_pet.image_url.present? %>
                      <%= image_tag friend_pet.image_url,
                            class: "rounded-circle me-3",
                            style: "width: 48px; height: 48px; object-fit: cover;" %>
                    <% else %>
                      <div class="rounded-circle border bg-light d-flex align-items-center justify-content-center me-3"
                           style="width: 48px; height: 48px;">
                        <i class="fa-solid fa-paw"></i>
                      </div>
                    <% end %>

                    <div>
                      <div class="fw-bold"><%= friend_pet.name %></div>
                      <div class="text-muted small">
                        owned by <%= friend_pet.user.username %>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>

              <% if (pet.pet_friends + pet.friended_by_pets).uniq.empty? %>
                <div class="text-muted">No pet friends yet.</div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
