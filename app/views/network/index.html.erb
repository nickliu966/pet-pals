<% content_for :title, "Network" %>

<% owner_friends = (current_user.owner_friends + current_user.friended_by_users).uniq %>
<% received_owner_requests = current_user.pending_received_user_friendships %>
<% sent_owner_requests = current_user.sent_user_friendships.pending %>
<% owner_request_count = received_owner_requests.count + sent_owner_requests.count %>

<% received_pet_requests = current_user.pets.flat_map { |pet| pet.received_pet_friendships.pending } %>
<% sent_pet_requests = current_user.pets.flat_map { |pet| pet.sent_pet_friendships.pending } %>
<% pet_request_count = received_pet_requests.count + sent_pet_requests.count %>

<div class="mb-4">
  <div class="page-kicker">Your social graph</div>
  <h1 class="page-title mb-1">Network</h1>
  <p class="page-subtitle mb-0">
    Manage owner friendships, pet friendships, and pending connection requests.
  </p>
</div>

<ul class="nav nav-pills app-tab-pills mb-4" id="network-tabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active"
            id="owner-tab"
            data-bs-toggle="tab"
            data-bs-target="#owner-network"
            type="button"
            role="tab">
      Owner friends
      <span class="badge text-bg-light"><%= owner_friends.count %></span>
    </button>
  </li>

  <li class="nav-item" role="presentation">
    <button class="nav-link"
            id="pet-tab"
            data-bs-toggle="tab"
            data-bs-target="#pet-network"
            type="button"
            role="tab">
      Pet friends
      <span class="badge text-bg-light"><%= current_user.pets.count %></span>
    </button>
  </li>
</ul>

<div class="tab-content">
  <div class="tab-pane fade show active" id="owner-network" role="tabpanel">
    <div class="network-card mb-4">
      <div class="network-card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <div class="section-card-title">Owner friends</div>
            <div class="text-muted small">
              People you have connected with.
            </div>
          </div>

          <button class="btn btn-outline-primary btn-sm rounded-pill px-3"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#owner-requests">
            Requests
            <span class="badge text-bg-primary"><%= owner_request_count %></span>
          </button>
        </div>

        <div class="collapse mb-3" id="owner-requests">
          <div class="request-panel">
            <div class="fw-bold mb-2">Pending owner requests</div>

            <% received_owner_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center gap-3 border-bottom py-2">
                <div>
                  <%= link_to friendship.requester.username,
                        user_path(friendship.requester.username),
                        class: "text-decoration-none fw-bold" %>
                  wants to be your friend.
                </div>

                <div class="d-flex gap-2 flex-shrink-0">
                  <%= button_to "Accept",
                        user_friendship_path(friendship),
                        method: :patch,
                        params: { user_friendship: { status: "accepted" } },
                        class: "btn btn-primary btn-sm rounded-pill px-3" %>

                  <%= button_to "Decline",
                        user_friendship_path(friendship),
                        method: :patch,
                        params: { user_friendship: { status: "declined" } },
                        class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
                </div>
              </div>
            <% end %>

            <% sent_owner_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center gap-3 border-bottom py-2">
                <div>
                  Requested
                  <%= link_to friendship.receiver.username,
                        user_path(friendship.receiver.username),
                        class: "text-decoration-none fw-bold" %>
                </div>

                <%= button_to "Cancel",
                      user_friendship_path(friendship),
                      method: :delete,
                      class: "btn btn-outline-danger btn-sm rounded-pill px-3" %>
              </div>
            <% end %>

            <% if owner_request_count.zero? %>
              <div class="text-muted">No owner requests.</div>
            <% end %>
          </div>
        </div>

        <% if owner_friends.any? %>
          <div class="vstack gap-2">
            <% owner_friends.each do |user| %>
              <%= link_to user_path(user.username),
                    class: "network-friend-card" do %>
                <div class="d-flex align-items-center gap-3 min-width-0">
                  <% if user.avatar_image.attached? %>
                    <%= image_tag user.avatar_image,
                          class: "rounded-circle owner-card-avatar flex-shrink-0" %>
                  <% else %>
                    <div class="owner-card-avatar-fallback flex-shrink-0">
                      <%= user.username.first.upcase %>
                    </div>
                  <% end %>

                  <div class="min-width-0">
                    <div class="fw-bold text-truncate"><%= user.username %></div>

                    <% if user.display_name.present? %>
                      <div class="text-muted small text-truncate"><%= user.display_name %></div>
                    <% end %>
                  </div>
                </div>

                <span class="text-muted">
                  <i class="fa-solid fa-chevron-right"></i>
                </span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="fa-solid fa-user-group"></i>
            </div>
            <h5 class="mb-1">No owner friends yet</h5>
            <p class="text-muted mb-0">
              Search for owners and send a connection request.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="tab-pane fade" id="pet-network" role="tabpanel">
    <div class="network-card mb-4">
      <div class="network-card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <div class="section-card-title">Pet friends</div>
            <div class="text-muted small">
              Friendships grouped by your pets.
            </div>
          </div>

          <button class="btn btn-outline-primary btn-sm rounded-pill px-3"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#pet-requests">
            Requests
            <span class="badge text-bg-primary"><%= pet_request_count %></span>
          </button>
        </div>

        <div class="collapse mb-3" id="pet-requests">
          <div class="request-panel">
            <div class="fw-bold mb-2">Pending pet requests</div>

            <% received_pet_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center gap-3 border-bottom py-2">
                <div>
                  <%= link_to friendship.requester_pet.name,
                        pet_path(friendship.requester_pet),
                        class: "text-decoration-none fw-bold" %>
                  wants to be friends with
                  <%= link_to friendship.receiver_pet.name,
                        pet_path(friendship.receiver_pet),
                        class: "text-decoration-none fw-bold" %>.
                </div>

                <div class="d-flex gap-2 flex-shrink-0">
                  <%= button_to "Accept",
                        pet_friendship_path(friendship),
                        method: :patch,
                        params: { pet_friendship: { status: "accepted" } },
                        class: "btn btn-primary btn-sm rounded-pill px-3" %>

                  <%= button_to "Decline",
                        pet_friendship_path(friendship),
                        method: :patch,
                        params: { pet_friendship: { status: "declined" } },
                        class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
                </div>
              </div>
            <% end %>

            <% sent_pet_requests.each do |friendship| %>
              <div class="d-flex justify-content-between align-items-center gap-3 border-bottom py-2">
                <div>
                  <%= friendship.requester_pet.name %> requested
                  <%= link_to friendship.receiver_pet.name,
                        pet_path(friendship.receiver_pet),
                        class: "text-decoration-none fw-bold" %>
                </div>

                <%= button_to "Cancel",
                      pet_friendship_path(friendship),
                      method: :delete,
                      class: "btn btn-outline-danger btn-sm rounded-pill px-3" %>
              </div>
            <% end %>

            <% if pet_request_count.zero? %>
              <div class="text-muted">No pet requests.</div>
            <% end %>
          </div>
        </div>

        <% if current_user.pets.any? %>
          <% current_user.pets.each do |pet| %>
            <% pet_friends = (pet.pet_friends + pet.friended_by_pets).uniq %>

            <div class="network-pet-section">
              <div class="d-flex align-items-center justify-content-between mb-2">
                <h6 class="mb-0">
                  <%= link_to pet.name, pet_path(pet), class: "text-decoration-none" %>
                </h6>

                <span class="badge text-bg-secondary rounded-pill">
                  <%= pluralize(pet_friends.count, "friend") %>
                </span>
              </div>

              <% if pet_friends.any? %>
                <div class="vstack gap-2">
                  <% pet_friends.each do |friend_pet| %>
                    <%= link_to pet_path(friend_pet),
                          class: "network-friend-card" do %>
                      <div class="d-flex align-items-center gap-3 min-width-0">
                        <% if friend_pet.image_url.present? %>
                          <%= image_tag friend_pet.image_url,
                                class: "rounded-circle owner-card-avatar flex-shrink-0" %>
                        <% else %>
                          <div class="owner-card-avatar-fallback flex-shrink-0">
                            <i class="fa-solid fa-paw"></i>
                          </div>
                        <% end %>

                        <div class="min-width-0">
                          <div class="fw-bold text-truncate"><%= friend_pet.name %></div>
                          <div class="text-muted small text-truncate">
                            owned by <%= friend_pet.user.username %>
                          </div>
                        </div>
                      </div>

                      <span class="text-muted">
                        <i class="fa-solid fa-chevron-right"></i>
                      </span>
                    <% end %>
                  <% end %>
                </div>
              <% else %>
                <div class="text-muted small">
                  No pet friends yet.
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="fa-solid fa-paw"></i>
            </div>
            <h5 class="mb-1">No pets yet</h5>
            <p class="text-muted mb-0">
              Add a pet before building pet friendships.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
