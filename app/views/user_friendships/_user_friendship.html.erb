<% content_for :title, "Owner Friends" %>

<h1>Owner Friends</h1>

<h3 class="mt-4">Pending requests</h3>

<ul class="list-group list-group-flush mb-4">
  <% current_user.pending_received_user_friendships.each do |friendship| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <div>
        <%= link_to friendship.requester.name,
              user_path(friendship.requester),
              class: "text-decoration-none" %>
        wants to be your friend.
      </div>

      <div class="d-flex gap-2">
        <%= button_to "Accept",
              user_friendship_path(friendship),
              method: :patch,
              params: { user_friendship: { status: "accepted" } },
              class: "btn btn-primary btn-sm" %>

        <%= button_to "Decline",
              user_friendship_path(friendship),
              method: :patch,
              params: { user_friendship: { status: "declined" } },
              class: "btn btn-outline-secondary btn-sm" %>
      </div>
    </li>
  <% end %>
</ul>

<h3>Your friends</h3>

<ul class="list-group list-group-flush">
  <% (current_user.owner_friends + current_user.friended_by_users).uniq.each do |user| %>
    <li class="list-group-item">
      <%= link_to user.name, user_path(user), class: "text-decoration-none" %>
    </li>
  <% end %>
</ul>
