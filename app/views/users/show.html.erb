<% content_for :title, @user.username %>

<% can_view_private_content = allowed_to?(:show?, @user) %>

<% posts_count = @user.posts.count %>
<% pets_count = @user.pets.count %>
<% followers_count = @user.follower_users.count %>
<% following_count = @user.following_users.count %>
<% friends_count = @user.mutual_friends.count %>

<div class="card profile-hero mb-4">
  <% if @user.profile_banner.attached? %>
    <%= image_tag @user.profile_banner,
          class: "card-img-top profile-banner" %>
  <% else %>
    <div class="profile-banner"></div>
  <% end %>

  <div class="profile-body">
    <div class="d-flex justify-content-between align-items-start gap-3">
      <div class="d-flex align-items-end gap-3 profile-name-row">
        <div class="profile-avatar-wrap flex-shrink-0">
          <% if @user.avatar_image.attached? %>
            <%= image_tag @user.avatar_image,
                  class: "rounded-circle profile-avatar" %>
          <% else %>
            <div class="profile-avatar-fallback">
              <%= @user.username.first.upcase %>
            </div>
          <% end %>
        </div>

        <div class="pb-2 min-width-0">
          <div class="d-flex align-items-center flex-wrap gap-2">
            <h1 class="page-title mb-0">
              <%= @user.username %>
            </h1>

            <% if @user.private? %>
              <span class="profile-badge">
                <i class="fa-solid fa-lock"></i>
                Private
              </span>
            <% end %>
          </div>

          <% if @user.display_name.present? %>
            <div class="profile-handle">
              <%= @user.display_name %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="pt-3 flex-shrink-0">
        <% if @user == current_user %>
          <button type="button"
                  class="btn btn-outline-secondary rounded-pill px-3 profile-follow-button"
                  data-bs-toggle="modal"
                  data-bs-target="#editProfileModal">
            <i class="fa-solid fa-pen me-1"></i>
            Edit profile
          </button>
        <% else %>
          <% sent_follow = current_user.sent_user_friendships.find_by(receiver: @user) %>
          <% received_follow = current_user.received_user_friendships.find_by(requester: @user) %>

          <% if sent_follow&.accepted? %>
            <%= button_to "Unfollow",
                  user_friendship_path(sent_follow),
                  method: :delete,
                  class: "btn btn-outline-danger rounded-pill px-3 profile-follow-button" %>

          <% elsif sent_follow&.pending? %>
            <%= button_to "Cancel request",
                  user_friendship_path(sent_follow),
                  method: :delete,
                  class: "btn btn-outline-secondary rounded-pill px-3 profile-follow-button" %>

          <% elsif received_follow&.accepted? %>
            <%= button_to "Follow back",
                  user_friendships_path,
                  method: :post,
                  params: { user_friendship: { receiver_id: @user.id } },
                  class: "btn btn-primary rounded-pill px-3 profile-follow-button" %>

          <% elsif received_follow&.pending? %>
            <%= link_to "Respond",
                  notifications_path,
                  class: "btn btn-outline-primary rounded-pill px-3 profile-follow-button" %>

          <% else %>
            <%= button_to (@user.private? ? "Request" : "Follow"),
                  user_friendships_path,
                  method: :post,
                  params: { user_friendship: { receiver_id: @user.id } },
                  class: "btn btn-primary rounded-pill px-3 profile-follow-button" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if can_view_private_content %>
      <div class="profile-stats-grid my-4">
        <div class="profile-stat">
          <strong><%= posts_count %></strong>
          <span>posts</span>
        </div>

        <%= link_to user_pets_path(@user.username),
              class: "profile-stat" do %>
          <strong><%= pets_count %></strong>
          <span>pets</span>
        <% end %>

        <%= link_to followers_path(@user.username),
              class: "profile-stat" do %>
          <strong><%= followers_count %></strong>
          <span>followers</span>
        <% end %>

        <%= link_to follows_path(@user.username),
              class: "profile-stat" do %>
          <strong><%= following_count %></strong>
          <span>following</span>
        <% end %>

        <%= link_to user_friends_path(@user.username),
              class: "profile-stat" do %>
          <strong><%= friends_count %></strong>
          <span>friends</span>
        <% end %>
      </div>

      <div class="profile-detail-line mb-3">
        <% if @user.city.present? %>
          <span class="profile-detail-pill">
            <i class="fa-solid fa-location-dot"></i>
            <%= @user.city %>
          </span>
        <% end %>

        <% if @user.website.present? %>
          <% website_url =
               if @user.website.start_with?("http://", "https://")
                 @user.website
               else
                 "https://#{@user.website}"
               end %>

          <%= link_to website_url,
                target: "_blank",
                class: "profile-detail-pill" do %>
            <i class="fa-solid fa-link"></i>
            Website
          <% end %>
        <% end %>
      </div>

      <% if @user.bio.present? %>
        <div class="profile-bio">
          <%= simple_format(@user.bio, class: "mb-0") %>
        </div>
      <% end %>
    <% else %>
      <div class="text-muted mt-3">
        <i class="fa-solid fa-lock me-1"></i>
        This account is private.
      </div>
    <% end %>
  </div>
</div>

<% if can_view_private_content %>
  <div class="mb-3">
    <div class="page-kicker">Profile activity</div>
    <h3 class="page-title fs-4 mb-0">Posts</h3>
  </div>

  <% if @posts.any? %>
    <ul class="list-group list-group-flush">
      <%= render partial: "posts/post",
            collection: @posts,
            layout: "layouts/list_group",
            locals: { render_edit_modal: false } %>
    </ul>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-icon">
        <i class="fa-solid fa-camera"></i>
      </div>
      <h5 class="mb-1">No posts yet</h5>
      <p class="text-muted mb-0">
        Posts shared by <%= @user.username %> will appear here.
      </p>
    </div>
  <% end %>
<% else %>
  <div class="empty-state">
    <div class="empty-state-icon">
      <i class="fa-solid fa-lock"></i>
    </div>

    <h5 class="mb-1">This account is private</h5>
    <p class="text-muted mb-0">
      Request to follow them to see their posts and pets.
    </p>
  </div>
<% end %>

<% if @user == current_user %>
  <% content_for :modals do %>
    <div class="modal fade"
         id="editProfileModal"
         tabindex="-1"
         aria-labelledby="editProfileModalLabel"
         aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <div>
              <div class="page-kicker">Settings</div>
              <h5 class="modal-title" id="editProfileModalLabel">
                Edit profile
              </h5>
            </div>

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Close">
            </button>
          </div>

          <div class="modal-body">
            <%= render "users/profile_form", user: current_user %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
