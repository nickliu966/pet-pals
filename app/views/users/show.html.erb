<% content_for :title, @user.username %>

<% can_view_private_content = allowed_to?(:show?, @user) %>

<% posts_count = @user.posts.count %>
<% pets_count = @user.pets.count %>
<% followers_count = @user.follower_users.count %>
<% following_count = @user.following_users.count %>
<% friends_count = @user.mutual_friends.count %>

<div class="card mb-4">
  <% if @user.profile_banner.attached? %>
    <%= image_tag @user.profile_banner,
          class: "card-img-top",
          style: "height: 180px; object-fit: cover;" %>
  <% end %>

  <div class="card-body">
    <div class="d-flex gap-4 align-items-start">
      <div>
        <% if @user.avatar_image.attached? %>
          <%= image_tag @user.avatar_image,
                class: "rounded-circle border",
                style: "width: 110px; height: 110px; object-fit: cover;" %>
        <% else %>
          <div class="rounded-circle border bg-light d-flex align-items-center justify-content-center"
               style="width: 110px; height: 110px; font-size: 36px;">
            <%= @user.username.first.upcase %>
          </div>
        <% end %>
      </div>

      <div class="flex-grow-1">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <div>
            <h1 class="mb-0">
              <%= @user.username %>
            </h1>

            <% if @user.display_name.present? %>
              <div class="text-muted">
                <%= @user.display_name %>
              </div>
            <% end %>
          </div>

          <div>
            <% if @user == current_user %>
              <button type="button"
                      class="btn btn-sm btn-outline-secondary profile-follow-button"
                      data-bs-toggle="modal"
                      data-bs-target="#editProfileModal">
                Edit profile
              </button>
            <% else %>
              <% sent_follow = current_user.sent_user_friendships.find_by(receiver: @user) %>
              <% received_follow = current_user.received_user_friendships.find_by(requester: @user) %>

              <% if sent_follow&.accepted? %>
                <%= button_to "Unfollow",
                      user_friendship_path(sent_follow),
                      method: :delete,
                      class: "btn btn-sm btn-outline-danger profile-follow-button" %>

              <% elsif sent_follow&.pending? %>
                <%= button_to "Cancel request",
                      user_friendship_path(sent_follow),
                      method: :delete,
                      class: "btn btn-sm btn-outline-secondary profile-follow-button" %>

              <% elsif received_follow&.accepted? %>
                <%= button_to "Follow back",
                      user_friendships_path,
                      method: :post,
                      params: { user_friendship: { receiver_id: @user.id } },
                      class: "btn btn-sm btn-primary profile-follow-button" %>

              <% elsif received_follow&.pending? %>
                <%= link_to "Respond",
                      notifications_path,
                      class: "btn btn-sm btn-outline-primary profile-follow-button" %>

              <% else %>
                <%= button_to (@user.private? ? "Request" : "Follow"),
                      user_friendships_path,
                      method: :post,
                      params: { user_friendship: { receiver_id: @user.id } },
                      class: "btn btn-sm btn-primary profile-follow-button" %>
              <% end %>
            <% end %>
          </div>
        </div>

        <% if can_view_private_content %>
          <div class="d-flex gap-4 mb-3">
            <div>
              <strong><%= posts_count %></strong>
              posts
            </div>

            <%= link_to user_pets_path(@user.username),
                  class: "text-dark text-decoration-none" do %>
              <strong><%= pets_count %></strong>
              pets
            <% end %>

            <%= link_to followers_path(@user.username),
                  class: "text-dark text-decoration-none" do %>
              <strong><%= followers_count %></strong>
              followers
            <% end %>

            <%= link_to follows_path(@user.username),
                  class: "text-dark text-decoration-none" do %>
              <strong><%= following_count %></strong>
              following
            <% end %>

            <%= link_to user_friends_path(@user.username),
                  class: "text-dark text-decoration-none" do %>
              <strong><%= friends_count %></strong>
              friends
            <% end %>
          </div>

          <% if @user.bio.present? %>
            <div class="profile-bio">
              <%= simple_format(@user.bio, class: "mb-0") %>
            </div>
          <% end %>
        <% else %>
          <div class="text-muted mt-2">
            <i class="fa-solid fa-lock me-1"></i>
            This account is private.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if can_view_private_content %>
  <h3>Posts</h3>

  <% if @posts.any? %>
    <ul class="list-group list-group-flush">
      <%= render partial: "posts/post",
            collection: @posts,
            layout: "layouts/list_group",
            locals: { render_edit_modal: false } %>
    </ul>
  <% else %>
    <p class="text-muted">
      No posts yet.
    </p>
  <% end %>
<% else %>
  <div class="card">
    <div class="card-body text-center text-muted">
      <div class="mb-2">
        <i class="fa-solid fa-lock fa-lg"></i>
      </div>

      <div>
        This account is private.
      </div>

      <div class="small">
        Request to follow them to see their posts and pets.
      </div>
    </div>
  </div>
<% end %>

<% if @user == current_user %>
  <% content_for :modals do %>
    <div class="modal fade"
         id="editProfileModal"
         tabindex="-1"
         aria-labelledby="editProfileModalLabel"
         aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="editProfileModalLabel">
              Edit profile
            </h5>

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Close">
            </button>
          </div>

          <div class="modal-body">
            <%= render "users/profile_form", user: current_user %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
