<% content_for :title, "#{@user.username}'s following" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="mb-0">Following</h1>
    <div class="text-muted">
      <%= pluralize(@follows.count, "account") %>
    </div>
  </div>

  <%= link_to "Back",
        user_path(@user.username),
        class: "btn btn-outline-secondary" %>
</div>

<% if @follows.any? %>
  <div class="list-group">
    <% @follows.each do |user| %>
      <%= link_to user_path(user.username),
            class: "list-group-item list-group-item-action" do %>
        <div class="fw-bold">
          <%= user.username %>
        </div>

        <% if user.display_name.present? %>
          <div class="text-muted small">
            <%= user.display_name %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">
    Not following anyone yet.
  </p>
<% end %>
