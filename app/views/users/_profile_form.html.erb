<%= form_with(model: user, url: update_user_path(user.username), method: :patch) do |form| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group mb-2">
    <%= form.label :email %>
    <%= form.email_field :email, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :username %>
    <%= form.text_field :username, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :display_name %>
    <%= form.text_field :display_name, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :bio %>
    <%= form.text_area :bio, class: "form-control", rows: 3 %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :city %>
    <%= form.text_field :city, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :website %>
    <%= form.text_field :website, class: "form-control" %>
  </div>

  <div class="form-check mb-3">
    <%= form.check_box :private, class: "form-check-input" %>
    <%= form.label :private, "Make my profile private", class: "form-check-label" %>

    <div class="form-text">
      People can still visit your profile page, but non-friends cannot see your posts, pets, followers, or following.
    </div>
  </div>

  <div class="form-group mb-3">
    <%= form.label :current_password %>
    <%= form.password_field :current_password, class: "form-control" %>

    <div class="form-text">
      Required to save profile changes.
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
      Cancel
    </button>

    <%= form.submit "Update profile", class: "btn btn-primary" %>
  </div>
<% end %>
