<%= form_with(model: user, url: update_user_path(user.username), method: :patch) do |form| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= form.label :email, class: "form-label fw-semibold" %>
      <%= form.email_field :email,
            class: "form-control",
            placeholder: "you@example.com" %>
    </div>

    <div class="col-md-6">
      <%= form.label :username, class: "form-label fw-semibold" %>
      <%= form.text_field :username,
            class: "form-control",
            placeholder: "username" %>
    </div>

    <div class="col-md-6">
      <%= form.label :display_name, class: "form-label fw-semibold" %>
      <%= form.text_field :display_name,
            class: "form-control",
            placeholder: "Display name" %>
    </div>

    <div class="col-md-6">
      <%= form.label :city, class: "form-label fw-semibold" %>
      <%= form.text_field :city,
            class: "form-control",
            placeholder: "City" %>
    </div>

    <div class="col-12">
      <%= form.label :website, class: "form-label fw-semibold" %>
      <%= form.text_field :website,
            class: "form-control",
            placeholder: "https://example.com" %>
    </div>

    <div class="col-12">
      <%= form.label :bio, class: "form-label fw-semibold" %>
      <%= form.text_area :bio,
            class: "form-control",
            rows: 4,
            placeholder: "Tell other pet people about you." %>
    </div>

    <div class="col-12">
      <div class="form-check p-3 rounded border bg-light">
        <%= form.check_box :private, class: "form-check-input" %>
        <%= form.label :private, "Make my profile private", class: "form-check-label fw-semibold" %>

        <div class="form-text">
          People can still visit your profile page, but non-friends cannot see your posts, pets, followers, or following.
        </div>
      </div>
    </div>

    <div class="col-12">
      <%= form.label :current_password, class: "form-label fw-semibold" %>
      <%= form.password_field :current_password,
            class: "form-control",
            placeholder: "Current password" %>

      <div class="form-text">
        Required to save profile changes.
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <button type="button"
            class="btn btn-outline-secondary rounded-pill px-4"
            data-bs-dismiss="modal">
      Cancel
    </button>

    <%= form.submit "Update profile",
          class: "btn btn-primary rounded-pill px-4" %>
  </div>
<% end %>
