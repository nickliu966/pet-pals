<% content_for :title, "#{@user.username}'s friends" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="mb-0"><%= @user.username %>'s network</h1>
    <div class="text-muted">
      <%= pluralize(@followers.count, "follower") %>
      ·
      <%= @following.count %> following
    </div>
  </div>

  <%= link_to "Back",
        user_path(@user.username),
        class: "btn btn-outline-secondary" %>
</div>

<h4>Followers</h4>

<div class="list-group list-group-flush mb-4">
  <% @followers.each do |user| %>
    <div class="list-group-item d-flex justify-content-between align-items-center">
      <div class="d-flex align-items-center">
        <% if user.avatar_image.attached? %>
          <%= image_tag user.avatar_image,
                class: "rounded-circle me-3",
                style: "width: 56px; height: 56px; object-fit: cover;" %>
        <% else %>
          <div class="rounded-circle border bg-light d-flex align-items-center justify-content-center me-3"
               style="width: 56px; height: 56px;">
            <%= user.username.first.upcase %>
          </div>
        <% end %>

        <div>
          <div>
            <%= link_to user.username,
                  user_path(user.username),
                  class: "text-decoration-none fw-bold" %>
          </div>

          <% if user.display_name.present? %>
            <div class="text-muted">
              <%= user.display_name %>
            </div>
          <% end %>
        </div>
      </div>

      <%= link_to "View",
            user_path(user.username),
            class: "btn btn-outline-primary btn-sm" %>
    </div>
  <% end %>

  <% if @followers.empty? %>
    <div class="list-group-item text-muted">
      No followers yet.
    </div>
  <% end %>
</div>

<h4>Following</h4>

<div class="list-group list-group-flush">
  <% @following.each do |user| %>
    <div class="list-group-item d-flex justify-content-between align-items-center">
      <div class="d-flex align-items-center">
        <% if user.avatar_image.attached? %>
          <%= image_tag user.avatar_image,
                class: "rounded-circle me-3",
                style: "width: 56px; height: 56px; object-fit: cover;" %>
        <% else %>
          <div class="rounded-circle border bg-light d-flex align-items-center justify-content-center me-3"
               style="width: 56px; height: 56px;">
            <%= user.username.first.upcase %>
          </div>
        <% end %>

        <div>
          <div>
            <%= link_to user.username,
                  user_path(user.username),
                  class: "text-decoration-none fw-bold" %>
          </div>

          <% if user.display_name.present? %>
            <div class="text-muted">
              <%= user.display_name %>
            </div>
          <% end %>
        </div>
      </div>

      <%= link_to "View",
            user_path(user.username),
            class: "btn btn-outline-primary btn-sm" %>
    </div>
  <% end %>

  <% if @following.empty? %>
    <div class="list-group-item text-muted">
      Not following anyone yet.
    </div>
  <% end %>
</div>
