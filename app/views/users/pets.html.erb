<% content_for :title, "#{@user.username}'s pets" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="mb-0"><%= @user.username %>'s pets</h1>
    <small class="text-muted"><%= pluralize(@pets.count, "pet") %></small>
  </div>

  <% if current_user == @user %>
    <button type="button"
            class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#addPetModal">
      New pet
    </button>
  <% end %>
</div>

<ul class="list-group list-group-flush">
  <% @pets.each do |pet| %>
    <li id="<%= dom_id(pet) %>" class="list-group-item">
      <div class="d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
          <% if pet.image_url.present? %>
            <%= image_tag pet.image_url,
                  class: "rounded-circle me-3",
                  style: "width: 64px; height: 64px; object-fit: cover;" %>
          <% end %>

          <div>
            <h5 class="mb-1">
              <%= link_to pet.name,
                    pet_path(pet),
                    class: "text-decoration-none" %>
            </h5>

            <div class="text-muted">
              <%= pet.species %> · <%= pet.breed %>
            </div>

            <div class="small">
              Owned by
              <%= link_to pet.user.username,
                    user_path(pet.user.username),
                    class: "text-decoration-none" %>
            </div>
          </div>
        </div>

        <div class="d-flex gap-2">
          <%= link_to "View",
                pet_path(pet),
                class: "btn btn-sm btn-outline-primary" %>

          <% if allowed_to?(:edit?, pet) %>
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
                    data-bs-toggle="modal"
                    data-bs-target="#<%= dom_id(pet, :form_modal) %>">
              Edit
            </button>

            <%= button_to "Delete",
                  pet_path(pet),
                  method: :delete,
                  class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </div>
      </div>
    </li>

    <% if allowed_to?(:edit?, pet) %>
      <% content_for :modals do %>
        <%= render "shared/form_modal",
              record: pet,
              modal_id: dom_id(pet, :form_modal),
              title: "Edit pet",
              form_partial: "pets/form",
              form_locals: {
                pet: pet,
                return_to: "#{request.fullpath}##{dom_id(pet)}",
                modal: true
              } %>
      <% end %>
    <% end %>
  <% end %>
</ul>
