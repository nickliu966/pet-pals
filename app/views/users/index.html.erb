<% content_for :title, "Search" %>

<div class="mb-4">
  <div class="page-kicker">Find people and pets</div>
  <h1 class="page-title mb-1">Search</h1>
  <p class="page-subtitle mb-0">
    Look up owners, pets, breeds, or species.
  </p>
</div>

<div class="card mb-4">
  <div class="card-body">
    <%= search_form_for @q, url: users_path, method: :get do |form| %>
      <div class="input-group">
        <span class="input-group-text bg-white">
          <i class="fa-solid fa-magnifying-glass text-muted"></i>
        </span>

        <%= form.search_field :username_or_display_name_cont,
              class: "form-control",
              placeholder: "Search owners or pets" %>

        <%= form.button class: "btn btn-primary px-4", name: nil do %>
          Search
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="mb-3">
  <div class="page-kicker">Results</div>
  <h2 class="page-title fs-4 mb-0">Owners</h2>
</div>

<% if @users.any? %>
  <div class="vstack gap-3 mb-4">
    <% @users.each do |user| %>
      <%= link_to user_path(user.username),
            class: "owner-card d-flex align-items-center justify-content-between gap-3" do %>
        <div class="d-flex align-items-center gap-3 min-width-0">
          <% if user.avatar_image.attached? %>
            <%= image_tag user.avatar_image,
                  class: "rounded-circle owner-card-avatar flex-shrink-0" %>
          <% else %>
            <div class="owner-card-avatar-fallback flex-shrink-0">
              <%= user.username.first.upcase %>
            </div>
          <% end %>

          <div class="min-width-0">
            <div class="fw-bold text-truncate">
              <%= user.username %>
            </div>

            <% if user.display_name.present? %>
              <div class="text-muted small text-truncate">
                <%= user.display_name %>
              </div>
            <% end %>
          </div>
        </div>

        <span class="text-muted">
          <i class="fa-solid fa-chevron-right"></i>
        </span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="empty-state mb-4">
    <div class="empty-state-icon">
      <i class="fa-solid fa-user-group"></i>
    </div>

    <h5 class="mb-1">No owners found</h5>
    <p class="text-muted mb-0">
      Try a different username or display name.
    </p>
  </div>
<% end %>

<div class="mb-3 mt-4">
  <div class="page-kicker">Pet results</div>
  <h2 class="page-title fs-4 mb-0">Pets</h2>
</div>

<% if @pets.any? %>
  <div class="vstack gap-3">
    <% @pets.each do |pet| %>
      <%= link_to pet_path(pet),
            class: "owner-card d-flex align-items-center justify-content-between gap-3" do %>
        <div class="d-flex align-items-center gap-3 min-width-0">
          <% if pet.image.attached? %>
            <%= image_tag pet.image,
                  class: "rounded-circle owner-card-avatar flex-shrink-0" %>
          <% elsif pet.image_url.present? %>
            <%= image_tag pet.image_url,
                  class: "rounded-circle owner-card-avatar flex-shrink-0" %>
          <% else %>
            <div class="owner-card-avatar-fallback flex-shrink-0">
              <i class="fa-solid fa-paw"></i>
            </div>
          <% end %>

          <div class="min-width-0">
            <div class="fw-bold text-truncate">
              <%= pet.name %>
            </div>

            <div class="text-muted small text-truncate">
              <% if pet.species.present? || pet.breed.present? %>
                <%= [pet.species, pet.breed].compact_blank.join(" · ") %>
                ·
              <% end %>
              owned by <%= pet.user.username %>
            </div>
          </div>
        </div>

        <span class="text-muted">
          <i class="fa-solid fa-chevron-right"></i>
        </span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <div class="empty-state-icon">
      <i class="fa-solid fa-paw"></i>
    </div>

    <h5 class="mb-1">No pets found</h5>
    <p class="text-muted mb-0">
      Try a pet name, breed, or species.
    </p>
  </div>
<% end %>
