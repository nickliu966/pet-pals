<% comments_count = post.comments_count.to_i %>
<% if comments_count > 0 %>
  <% if expanded %>
    <div class="text-muted mb-1">
      <%= pluralize(post.comments.count, "comment") %>
    </div>
  <% else %>
    <button type="button"
            class="btn btn-link text-muted text-decoration-none p-0 mb-1"
            data-bs-toggle="modal"
            data-bs-target="#<%= comments_modal_id %>">
      View all <%= pluralize(comments_count, "comment") %>
    </button>
  <% end %>
<% end %>

<% unless expanded %>
  <% latest_comment =
     if post.comments.loaded?
       post.comments.min_by(&:created_at)
     else
       post.comments.default_order.first
     end %>

  <% if latest_comment.present? %>
    <div class="small">
      <strong>
        <%= link_to latest_comment.author.username,
              user_path(latest_comment.author.username),
              class: "text-dark text-decoration-none" %>
      </strong>

      <%= latest_comment.body %>
    </div>
  <% end %>
<% end %>
