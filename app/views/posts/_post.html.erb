<article id="<%= dom_id(post) %>" class="post-card">
  <% expanded = local_assigns.fetch(:expanded, false) %>
  <% render_edit_modal = local_assigns.fetch(:render_edit_modal, true) %>
  <% comments_modal_id = dom_id(post, :comments_modal) %>

  <% post_images = post.respond_to?(:images) ? post.images.to_a : [] %>
  <% post_comments =
       if post.comments.loaded?
         post.comments.sort_by(&:created_at)
       else
         post.comments.default_order
       end %>

  <% post_position =
       if defined?(post_counter)
         post_counter
       else
         0
       end %>

  <% priority_image = local_assigns.fetch(:priority_image, post_position < 3) %>
  <% image_loading = priority_image ? "eager" : "lazy" %>
  <% image_fetchpriority = priority_image ? "high" : "low" %>

  <% if post.respond_to?(:video) && post.video.attached? %>
    <div class="post-media is-loaded">
      <%= video_tag post.video,
            controls: true,
            class: "post-media-asset",
            style: "background: black;" %>
    </div>

  <% elsif post_images.any? %>
    <div class="post-media" data-controller="image-loading">
      <% if post_images.one? %>
        <%= image_tag post_images.first,
              class: "post-media-asset",
              loading: image_loading,
              fetchpriority: image_fetchpriority,
              decoding: "async",
              data: { action: "load->image-loading#loaded" } %>
      <% else %>
        <div id="postImages<%= post.id %>" class="carousel slide">
          <div class="carousel-inner">
            <% post_images.each_with_index do |image, index| %>
              <% slide_priority = priority_image && index.zero? %>

              <div class="carousel-item <%= "active" if index == 0 %>">
                <%= image_tag image,
                      class: "d-block post-media-asset",
                      loading: slide_priority ? "eager" : "lazy",
                      fetchpriority: slide_priority ? "high" : "low",
                      decoding: "async",
                      data: { action: "load->image-loading#loaded" } %>
              </div>
            <% end %>
          </div>

          <button class="carousel-control-prev"
                  type="button"
                  data-bs-target="#postImages<%= post.id %>"
                  data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>

          <button class="carousel-control-next"
                  type="button"
                  data-bs-target="#postImages<%= post.id %>"
                  data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        </div>
      <% end %>
    </div>

  <% elsif post.respond_to?(:image) && post.image.attached? %>
    <div class="post-media" data-controller="image-loading">
      <%= image_tag post.image,
            class: "post-media-asset",
            loading: image_loading,
            fetchpriority: image_fetchpriority,
            decoding: "async",
            data: { action: "load->image-loading#loaded" } %>
    </div>

  <% elsif post.image_url.present? %>
    <div class="post-media" data-controller="image-loading">
      <%= image_tag post.image_url,
            class: "post-media-asset",
            loading: image_loading,
            fetchpriority: image_fetchpriority,
            decoding: "async",
            data: { action: "load->image-loading#loaded" } %>
    </div>
  <% end %>

  <header class="post-header">
    <div class="d-flex justify-content-between align-items-start gap-3">
      <div class="d-flex align-items-start gap-3 min-width-0">
        <%= link_to user_path(post.user.username), class: "flex-shrink-0 text-decoration-none" do %>
          <% if post.user.avatar_image.attached? %>
            <%= image_tag post.user.avatar_image,
                  class: "rounded-circle post-author-avatar" %>
          <% else %>
            <span class="avatar-fallback">
              <%= post.user.username.first.upcase %>
            </span>
          <% end %>
        <% end %>

        <div class="min-width-0">
          <div class="fw-bold lh-sm">
            <%= link_to post.user.username,
                  user_path(post.user.username),
                  class: "text-dark text-decoration-none" %>
          </div>

          <div class="post-meta-line">
            <% if post.pet.present? %>
              with
              <%= link_to post.pet.name,
                    pet_path(post.pet),
                    class: "post-context-pill" %>
            <% end %>

            <% if post.walk_event.present? %>
              from
              <%= link_to post.walk_event.title,
                    walk_event_path(post.walk_event),
                    class: "post-context-pill" %>
            <% end %>

            <% if post.location_name.present? %>
              at
              <% if post.latitude.present? && post.longitude.present? %>
                <%= link_to post.location_name,
                      "https://www.google.com/maps/search/?api=1&query=#{post.latitude},#{post.longitude}",
                      target: "_blank",
                      rel: "noopener",
                      class: "post-context-pill" %>
              <% else %>
                <span class="post-context-pill">
                  <%= post.location_name %>
                </span>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="text-end flex-shrink-0">
        <% edited = post.updated_at > post.created_at + 1.minute %>

        <% if edited %>
          <details class="small text-muted">
            <summary class="text-muted" style="cursor: pointer;">
              edited <%= time_ago_in_words(post.updated_at) %> ago
            </summary>

            <div>
              originally posted <%= time_ago_in_words(post.created_at) %> ago
            </div>
          </details>
        <% else %>
          <small class="text-muted">
            <%= time_ago_in_words(post.created_at) %> ago
          </small>
        <% end %>
      </div>
    </div>
  </header>

  <div class="post-actions">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <div class="d-flex gap-2 align-items-center fs-4">
        <%= render "posts/like_button", post: post %>

        <% if expanded %>
          <%= link_to "##{dom_id(post, :comment_form)}",
                class: "post-action-button" do %>
            <i class="fa-regular fa-comment"></i>
          <% end %>
        <% else %>
          <button type="button"
                  class="btn btn-link post-action-button p-0 border-0 fs-4"
                  data-bs-toggle="modal"
                  data-bs-target="#<%= comments_modal_id %>">
            <i class="fa-regular fa-comment"></i>
          </button>
        <% end %>
      </div>

      <% if allowed_to?(:edit?, post) %>
        <div class="dropdown">
          <%= button_tag type: "button",
                class: "btn btn-link post-action-button p-0 border-0",
                data: { bs_toggle: "dropdown" },
                aria: { expanded: false } do %>
            <i class="fa-solid fa-ellipsis"></i>
          <% end %>

          <div class="dropdown-menu dropdown-menu-end p-0 post-actions-menu">
            <% if render_edit_modal %>
              <button type="button"
                      class="dropdown-item"
                      data-bs-toggle="modal"
                      data-bs-target="#<%= dom_id(post, :form_modal) %>">
                Edit
              </button>
            <% else %>
              <%= link_to "Edit",
                    edit_post_path(post, return_to: "#{request.fullpath}##{dom_id(post)}"),
                    class: "dropdown-item" %>
            <% end %>

            <div class="dropdown-divider m-0"></div>

            <div class="p-3 border-bottom">
              <%= form_with model: post, url: post_path(post), method: :patch, local: true do |form| %>
                <%= hidden_field_tag :return_to, "#{request.fullpath}##{dom_id(post)}" %>
                <%= hidden_field_tag :expanded, expanded %>

                <%= form.label :visibility, "Visibility", class: "form-label small fw-semibold mb-1" %>

                <%= form.select :visibility,
                      options_for_select(
                        [
                          ["Everyone", "everyone"],
                          ["Owner friends only", "user_friends_only"],
                          ["Pet friends only", "pet_friends_only"],
                          ["Friends of either", "friends_of_either"]
                        ],
                        post.visibility
                      ),
                      {},
                      class: "form-select form-select-sm",
                      onchange: "this.form.requestSubmit()" %>
              <% end %>
            </div>

            <%= button_to "Delete",
                  post_path(post),
                  method: :delete,
                  class: "dropdown-item text-danger rounded-0" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="post-body">
    <%= render "posts/likes_count",
          post: post,
          class_name: "metric-pill mb-2" %>

    <% if post.body.present? %>
      <div class="post-caption mb-2">
        <strong>
          <%= link_to post.user.username,
                user_path(post.user.username),
                class: "text-dark text-decoration-none" %>
        </strong>

        <%= link_mentions(post.body) %>
      </div>
    <% end %>

    <div id="<%= dom_id(post, :comments_summary) %>" class="post-comments-summary">
      <%= render "posts/comments_summary",
            post: post,
            expanded: expanded,
            comments_modal_id: comments_modal_id %>
    </div>
  </div>

  <% if expanded %>
    <ul id="<%= dom_id(post, :comments) %>" class="list-group list-group-flush border-top">
      <%= render post_comments %>
    </ul>

    <%= render "comments/expanded_form", post: post %>
  <% end %>
</article>

<% unless expanded %>
  <% content_for :modals do %>
    <%= render "posts/comments_modal",
          post: post,
          comments_modal_id: comments_modal_id,
          post_images: post_images,
          modal_comments: post_comments %>
  <% end %>
<% end %>

<% if allowed_to?(:edit?, post) && render_edit_modal %>
  <% content_for :modals do %>
    <%= render "shared/form_modal",
          record: post,
          modal_id: dom_id(post, :form_modal),
          title: "Edit post",
          form_partial: "posts/form",
          form_locals: {
            post: post,
            return_to: "#{request.fullpath}##{dom_id(post)}",
            modal: true,
            expanded: expanded
          } %>
  <% end %>
<% end %>
