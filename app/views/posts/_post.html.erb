<div id="<%= dom_id(post) %>">
  <% if post.respond_to?(:video) && post.video.attached? %>
    <%= video_tag post.video,
          controls: true,
          class: "w-100",
          style: "max-height: 420px; object-fit: cover; background: black;" %>

  <% elsif post.respond_to?(:images) && post.images.attached? %>
    <% if post.images.count == 1 %>
      <%= image_tag post.images.first,
            class: "w-100",
            style: "height: 360px; object-fit: cover;" %>
    <% else %>
      <div id="postImages<%= post.id %>" class="carousel slide">
        <div class="carousel-inner">
          <% post.images.each_with_index do |image, index| %>
            <div class="carousel-item <%= "active" if index == 0 %>">
              <%= image_tag image,
                    class: "d-block w-100",
                    style: "height: 360px; object-fit: cover;" %>
            </div>
          <% end %>
        </div>

        <button class="carousel-control-prev"
                type="button"
                data-bs-target="#postImages<%= post.id %>"
                data-bs-slide="prev">
          <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next"
                type="button"
                data-bs-target="#postImages<%= post.id %>"
                data-bs-slide="next">
          <span class="carousel-control-next-icon"></span>
        </button>
      </div>
    <% end %>

  <% elsif post.respond_to?(:image) && post.image.attached? %>
    <%= image_tag post.image,
          class: "w-100",
          style: "height: 360px; object-fit: cover;" %>

  <% elsif post.image_url.present? %>
    <%= image_tag post.image_url,
          class: "w-100",
          style: "height: 360px; object-fit: cover;" %>
  <% end %>

  <div class="p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <div>
        <strong>
          <%= link_to post.user.username,
                user_path(post.user.username),
                class: "text-decoration-none" %>
        </strong>

        <% if post.pet.present? %>
          <span class="text-muted">with</span>
          <%= link_to post.pet.name,
                pet_path(post.pet),
                class: "text-decoration-none" %>
        <% end %>

        <% if post.location_name.present? %>
          <span class="text-muted">at</span>

          <% if post.latitude.present? && post.longitude.present? %>
            <%= link_to post.location_name,
                  "https://www.google.com/maps/search/?api=1&query=#{post.latitude},#{post.longitude}",
                  target: "_blank",
                  class: "text-decoration-none" %>
          <% else %>
            <span><%= post.location_name %></span>
          <% end %>
        <% end %>
      </div>

      <small class="text-muted">
        <%= time_ago_in_words(post.created_at) %> ago
      </small>
    </div>

    <p class="mb-2">
      <%= post.body %>
    </p>

    <div class="d-flex justify-content-between align-items-center">
      <div class="d-flex gap-3 align-items-center">
        <% like = current_user.likes.find_by(post: post) %>

        <% if like.present? %>
          <%= button_to "Unlike",
                like,
                method: :delete,
                class: "btn btn-link text-decoration-none p-0" %>
        <% else %>
          <%= form_with(model: Like.new) do |form| %>
            <%= form.hidden_field :post_id, value: post.id %>
            <%= form.submit "Like",
                  class: "btn btn-link text-decoration-none p-0" %>
          <% end %>
        <% end %>

        <span>
          <%= pluralize(post.likes_count, "like") %>
        </span>

        <%= link_to "View post",
              post_path(post),
              class: "btn btn-link text-decoration-none p-0" %>
      </div>

        <% if current_user == post.user %>
          <div class="d-flex gap-2">
            <%= link_to "Edit",
                edit_post_path(post),
                class: "btn btn-sm btn-outline-secondary" %>

            <%= button_to "Delete",
                post_path(post),
                method: :delete,
                class: "btn btn-sm btn-outline-danger" %>
          </div>
        <% end %>
      </div>
    </div>

    <ul class="list-group list-group-flush border-top">
      <%= render post.comments.default_order %>
    </ul>

    <div class="border-top p-3">
      <%= form_with(model: Comment.new) do |form| %>
        <%= form.hidden_field :post_id, value: post.id %>

        <div class="form-group mb-2">
          <%= form.label :body, "Add a comment", class: "visually-hidden" %>
          <%= form.text_area :body,
              class: "form-control",
              placeholder: "Add a comment..." %>
        </div>

        <div class="d-grid">
          <%= form.submit "Comment", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
