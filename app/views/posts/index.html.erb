<% content_for :title, "Feed" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Feed</h1>

  <%= button_tag "New post",
      type: "button",
      class: "btn btn-primary",
      data: { bs_toggle: "modal", bs_target: "#new_post_modal" } %>
</div>

<ul id="feed" class="list-group list-group-flush">
  <%= render partial: "posts/post", collection: @posts, layout: "layouts/list_group" %>
</ul>
