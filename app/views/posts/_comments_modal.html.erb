<% post_images = local_assigns.fetch(:post_images) { post.respond_to?(:images) ? post.images.to_a : [] } %>
<% modal_comments =
     local_assigns.fetch(:modal_comments) do
       if post.comments.loaded?
         post.comments.sort_by(&:created_at)
       else
         post.comments.default_order
       end
     end %>

<div class="modal fade"
     id="<%= comments_modal_id %>"
     tabindex="-1"
     aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content overflow-hidden">
      <div class="row g-0">
        <div class="col-md-7 bg-black d-flex align-items-center justify-content-center">
          <% if post.respond_to?(:video) && post.video.attached? %>
            <%= video_tag post.video,
                  controls: true,
                  class: "w-100",
                  style: "max-height: 80vh; object-fit: contain; background: black;" %>

          <% elsif post_images.any? %>
            <% if post_images.one? %>
              <%= image_tag post_images.first,
                    class: "w-100",
                    style: "max-height: 80vh; object-fit: contain;" %>
            <% else %>
              <div id="<%= dom_id(post, :modal_images) %>" class="carousel slide w-100">
                <div class="carousel-inner">
                  <% post_images.each_with_index do |image, index| %>
                    <div class="carousel-item <%= "active" if index == 0 %>">
                      <%= image_tag image,
                            class: "d-block w-100",
                            style: "max-height: 80vh; object-fit: contain;" %>
                    </div>
                  <% end %>
                </div>

                <button class="carousel-control-prev"
                        type="button"
                        data-bs-target="#<%= dom_id(post, :modal_images) %>"
                        data-bs-slide="prev">
                  <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next"
                        type="button"
                        data-bs-target="#<%= dom_id(post, :modal_images) %>"
                        data-bs-slide="next">
                  <span class="carousel-control-next-icon"></span>
                </button>
              </div>
            <% end %>

          <% elsif post.respond_to?(:image) && post.image.attached? %>
            <%= image_tag post.image,
                  class: "w-100",
                  style: "max-height: 80vh; object-fit: contain;" %>

          <% elsif post.image_url.present? %>
            <%= image_tag post.image_url,
                  class: "w-100",
                  style: "max-height: 80vh; object-fit: contain;" %>
          <% end %>
        </div>

        <div class="col-md-5 d-flex flex-column" style="height: 80vh;">
          <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <div>
              <strong>
                <%= link_to post.user.username,
                      user_path(post.user.username),
                      class: "text-dark text-decoration-none" %>
              </strong>

              <% if post.location_name.present? %>
                <div class="small text-muted">
                  <%= post.location_name %>
                </div>
              <% end %>
            </div>

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Close"></button>
          </div>

          <div class="p-3 overflow-auto flex-grow-1">
            <% if post.body.present? %>
              <div class="mb-3">
                <strong>
                  <%= link_to post.user.username,
                        user_path(post.user.username),
                        class: "text-dark text-decoration-none" %>
                </strong>

                <%= post.body %>
              </div>
            <% end %>

            <div id="<%= dom_id(post, :modal_comments) %>">
              <% modal_comments.each do |comment| %>
                <%= render "comments/modal_comment", comment: comment %>
              <% end %>
            </div>
          </div>

          <div class="p-3 border-top">
            <%= render "posts/likes_count",
                  post: post,
                  target_id: dom_id(post, :modal_likes_count),
                  class_name: "fw-bold mb-2" %>

            <%= render "comments/modal_form", post: post %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
