<% content_for :title, "Home" %>

<% nearby_results_frame_id = "discover_posts_frame" %>

<% content_for :right_sidebar do %>
  <%= render "shared/nearby_filter", frame_id: nearby_results_frame_id %>
<% end %>

<div class="mb-4">
  <div class="page-kicker">Explore nearby moments</div>
  <h1 class="page-title mb-1">Discover</h1>
  <p class="page-subtitle mb-0">
    Public posts, park updates, walks, and pet-friendly places from the PetPals community.
  </p>
</div>

<%= render "posts/discover_results", posts: @posts %>
