<%= form_with(model: post) do |form| %>
  <% if post.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :pet_id, "Pet", class: "form-label" %>
    <%= form.collection_select :pet_id,
          current_user.pets,
          :id,
          :name,
          { prompt: "Choose a pet" },
          class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :body, "Caption", class: "form-label" %>
    <%= form.text_area :body,
          class: "form-control",
          rows: 4,
          placeholder: "What is your pet doing?" %>
  </div>

  <div class="mb-3">
    <%= form.label :image_url, "Image URL", class: "form-label" %>
    <%= form.text_field :image_url,
          class: "form-control",
          placeholder: "https://..." %>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
      Cancel
    </button>

    <%= form.submit "Create post", class: "btn btn-primary" %>
  </div>
<% end %>
