<% content_for :title, "Notifications" %>

<% request_count = @owner_requests.count + @pet_requests.count + @walk_invitations.count %>
<% activity_count = @post_likes.count + @post_comments.count %>

<div class="mb-4">
  <div class="page-kicker">Stay updated</div>
  <h1 class="page-title mb-1">Notifications</h1>
  <p class="page-subtitle mb-0">
    Review new friend requests, walk invitations, likes, and comments.
  </p>
</div>

<ul class="nav nav-pills app-tab-pills mb-4" id="notification-tabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active"
            id="requests-tab"
            data-bs-toggle="tab"
            data-bs-target="#requests-pane"
            type="button"
            role="tab">
      Requests
      <span class="badge text-bg-light"><%= request_count %></span>
    </button>
  </li>

  <li class="nav-item" role="presentation">
    <button class="nav-link"
            id="activity-tab"
            data-bs-toggle="tab"
            data-bs-target="#activity-pane"
            type="button"
            role="tab">
      Post activity
      <span class="badge text-bg-light"><%= activity_count %></span>
    </button>
  </li>
</ul>

<div class="tab-content">
  <div class="tab-pane fade show active" id="requests-pane" role="tabpanel">
    <div class="card section-card mb-4">
      <div class="section-card-header d-flex justify-content-between align-items-center">
        <div>
          <div class="section-card-title">Follow requests</div>
          <div class="text-muted small">People who want to connect with you.</div>
        </div>

        <span class="badge text-bg-secondary rounded-pill">
          <%= @owner_requests.count %>
        </span>
      </div>

      <div>
        <% @owner_requests.each do |friendship| %>
          <div class="notification-row">
            <div class="d-flex justify-content-between align-items-center gap-3">
              <div class="d-flex align-items-center gap-3 notification-copy">
                <% if friendship.requester.avatar_image.attached? %>
                  <%= image_tag friendship.requester.avatar_image,
                        class: "rounded-circle notification-avatar" %>
                <% else %>
                  <div class="notification-avatar-fallback">
                    <%= friendship.requester.username.first.upcase %>
                  </div>
                <% end %>

                <div>
                  <div>
                    <%= link_to friendship.requester.username,
                          user_path(friendship.requester.username) %>
                    requested to follow you.
                  </div>

                  <% if friendship.requester.display_name.present? %>
                    <div class="text-muted small">
                      <%= friendship.requester.display_name %>
                    </div>
                  <% end %>
                </div>
              </div>

              <div id="<%= dom_id(friendship, :notification_actions) %>" class="d-flex gap-2 flex-shrink-0">
                <% if friendship.status == "pending" %>
                  <%= button_to "Accept",
                        user_friendship_path(friendship, format: :turbo_stream),
                        method: :patch,
                        params: { user_friendship: { status: "accepted" } },
                        class: "btn btn-primary btn-sm rounded-pill px-3" %>

                  <%= button_to "Decline",
                        user_friendship_path(friendship, format: :turbo_stream),
                        method: :patch,
                        params: { user_friendship: { status: "declined" } },
                        class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
                <% else %>
                  <span class="btn btn-sm btn-outline-secondary disabled rounded-pill px-3">
                    <%= friendship.status.titleize %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <% if @owner_requests.empty? %>
          <div class="notification-row text-muted">
            No owner requests.
          </div>
        <% end %>
      </div>
    </div>

    <div class="card section-card mb-4">
      <div class="section-card-header d-flex justify-content-between align-items-center">
        <div>
          <div class="section-card-title">Pet requests</div>
          <div class="text-muted small">Pets asking to become friends.</div>
        </div>

        <span class="badge text-bg-secondary rounded-pill">
          <%= @pet_requests.count %>
        </span>
      </div>

      <div>
        <% @pet_requests.each do |friendship| %>
          <div class="notification-row">
            <div class="d-flex justify-content-between align-items-center gap-3">
              <div class="d-flex align-items-center gap-3 notification-copy">
                <div class="notification-icon">
                  <i class="fa-solid fa-paw"></i>
                </div>

                <div>
                  <div>
                    <%= link_to friendship.requester_pet.name,
                          pet_path(friendship.requester_pet) %>
                    wants to be friends with
                    <%= link_to friendship.receiver_pet.name,
                          pet_path(friendship.receiver_pet) %>.
                  </div>

                  <div class="text-muted small">
                    Requested by <%= friendship.requested_by_user.username %>
                  </div>
                </div>
              </div>

              <div id="<%= dom_id(friendship, :notification_actions) %>" class="d-flex gap-2 flex-shrink-0">
                <% if friendship.status == "pending" %>
                  <%= button_to "Accept",
                        pet_friendship_path(friendship, format: :turbo_stream),
                        method: :patch,
                        params: { pet_friendship: { status: "accepted" } },
                        class: "btn btn-primary btn-sm rounded-pill px-3" %>

                  <%= button_to "Decline",
                        pet_friendship_path(friendship, format: :turbo_stream),
                        method: :patch,
                        params: { pet_friendship: { status: "declined" } },
                        class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
                <% else %>
                  <span class="btn btn-sm btn-outline-secondary disabled rounded-pill px-3">
                    <%= friendship.status.titleize %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <% if @pet_requests.empty? %>
          <div class="notification-row text-muted">
            No pet requests.
          </div>
        <% end %>
      </div>
    </div>

    <div class="card section-card mb-4">
      <div class="section-card-header d-flex justify-content-between align-items-center">
        <div>
          <div class="section-card-title">Walk invitations</div>
          <div class="text-muted small">Walks you were invited to join.</div>
        </div>

        <span class="badge text-bg-secondary rounded-pill">
          <%= @walk_invitations.count %>
        </span>
      </div>

      <div>
        <% @walk_invitations.each do |invitation| %>
          <% walk_event = invitation.walk_event %>

          <div class="notification-row">
            <div class="d-flex justify-content-between align-items-center gap-3">
              <div class="d-flex align-items-center gap-3 notification-copy">
                <div class="notification-icon">
                  <i class="fa-solid fa-person-walking"></i>
                </div>

                <div>
                  <div>
                    <%= link_to walk_event.title,
                          walk_event_path(walk_event) %>

                    <span class="text-muted">
                      invitation from
                    </span>

                    <%= link_to walk_event.host_user.username,
                          user_path(walk_event.host_user.username) %>
                  </div>

                  <% if walk_event.start_time.present? || walk_event.location_name.present? %>
                    <div class="text-muted small">
                      <% if walk_event.start_time.present? %>
                        <%= walk_event.start_time.strftime("%b %-d, %-I:%M %p") %>
                      <% end %>

                      <% if walk_event.start_time.present? && walk_event.location_name.present? %>
                        ·
                      <% end %>

                      <% if walk_event.location_name.present? %>
                        <%= walk_event.location_name %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>

              <div id="<%= dom_id(invitation, :notification_actions) %>" class="d-flex gap-2 flex-shrink-0">
                <%= button_to "Accept",
                      accept_walk_participant_path(invitation, format: :turbo_stream),
                      method: :patch,
                      params: { return_to: notifications_path },
                      class: "btn btn-primary btn-sm rounded-pill px-3" %>

                <%= button_to "Decline",
                      decline_walk_participant_path(invitation, format: :turbo_stream),
                      method: :patch,
                      params: { return_to: notifications_path },
                      class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
              </div>
            </div>
          </div>
        <% end %>

        <% if @walk_invitations.empty? %>
          <div class="notification-row text-muted">
            No walk invitations.
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="tab-pane fade" id="activity-pane" role="tabpanel">
    <div class="card section-card mb-4">
      <div class="section-card-header d-flex justify-content-between align-items-center">
        <div>
          <div class="section-card-title">Likes on your posts</div>
          <div class="text-muted small">Recent appreciation from other users.</div>
        </div>

        <span class="badge text-bg-secondary rounded-pill">
          <%= @post_likes.count %>
        </span>
      </div>

      <div>
        <% @post_likes.each do |like| %>
          <%= link_to post_path(like.post, return_to: notifications_path),
                class: "notification-row d-block text-decoration-none text-dark" do %>
            <div class="d-flex align-items-center gap-3">
              <% if like.fan.avatar_image.attached? %>
                <%= image_tag like.fan.avatar_image,
                      class: "rounded-circle notification-avatar" %>
              <% else %>
                <div class="notification-avatar-fallback">
                  <%= like.fan.username.first.upcase %>
                </div>
              <% end %>

              <div class="notification-copy">
                <span class="fw-bold"><%= like.fan.username %></span>
                liked your post.

                <div class="text-muted small">
                  <%= time_ago_in_words(like.created_at) %> ago
                </div>
              </div>
            </div>
          <% end %>
        <% end %>

        <% if @post_likes.empty? %>
          <div class="notification-row text-muted">
            No likes yet.
          </div>
        <% end %>
      </div>
    </div>

    <div class="card section-card mb-4">
      <div class="section-card-header d-flex justify-content-between align-items-center">
        <div>
          <div class="section-card-title">Comments on your posts</div>
          <div class="text-muted small">Recent replies to your posts.</div>
        </div>

        <span class="badge text-bg-secondary rounded-pill">
          <%= @post_comments.count %>
        </span>
      </div>

      <div>
        <% @post_comments.each do |comment| %>
          <%= link_to post_path(comment.post, return_to: notifications_path),
                class: "notification-row d-block text-decoration-none text-dark" do %>
            <div class="d-flex align-items-start gap-3">
              <% if comment.author.avatar_image.attached? %>
                <%= image_tag comment.author.avatar_image,
                      class: "rounded-circle notification-avatar" %>
              <% else %>
                <div class="notification-avatar-fallback">
                  <%= comment.author.username.first.upcase %>
                </div>
              <% end %>

              <div class="notification-copy">
                <div>
                  <span class="fw-bold"><%= comment.author.username %></span>
                  commented on your post.
                </div>

                <div class="text-muted small mb-1">
                  <%= time_ago_in_words(comment.created_at) %> ago
                </div>

                <div>
                  <%= truncate(comment.body, length: 90) %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>

        <% if @post_comments.empty? %>
          <div class="notification-row text-muted">
            No comments yet.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
