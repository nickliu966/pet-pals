<% content_for :title, "Walks" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Walks</h1>

  <button type="button"
        class="btn btn-primary"
        data-bs-toggle="modal"
        data-bs-target="#createWalkModal">
    Create walk
  </button>
</div>

<ul id="walk_events" class="list-group list-group-flush">
  <%= render partial: "walk_events/walk_event",
             collection: @walk_events,
             layout: "layouts/list_group" %>
</ul>
