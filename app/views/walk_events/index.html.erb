<% content_for :title, "Walks" %>

<% content_for :right_sidebar do %>
  <%= render "shared/nearby_filter" %>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Walks</h1>

  <button type="button"
          class="btn btn-primary"
          data-bs-toggle="modal"
          data-bs-target="#createWalkModal">
    Create walk
  </button>
</div>

<div class="card mb-3">
  <div class="card-body">
    <%= search_form_for @q, url: walk_events_path, method: :get do |form| %>
      <div class="input-group">
        <%= form.search_field :title_or_note_or_location_name_cont,
              class: "form-control",
              placeholder: "Search walks by title, note, or location" %>

        <%= form.submit "Search", class: "btn btn-outline-primary" %>

        <% if params[:q].present? %>
          <%= link_to "Clear",
                walk_events_path,
                class: "btn btn-outline-secondary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<% if @walk_events.any? %>
  <div class="vstack gap-3">
    <%= render partial: "walk_events/walk_event",
          collection: @walk_events,
          as: :walk_event,
          locals: { render_edit_modal: false } %>
  </div>
<% else %>
  <div class="card my-3">
    <div class="card-body text-center text-muted">
      <% if params[:near_me] == "1" && params[:radius_miles].present? %>
        <h5 class="card-title">No nearby walks found</h5>
        <p class="mb-0">
          There are no visible walk events within
          <%= pluralize(params[:radius_miles].to_i, "mile") %>
          of your current location.
        </p>
      <% else %>
        <h5 class="card-title">No walks found</h5>
        <p class="mb-0">
          Visible walk events will appear here.
        </p>
      <% end %>
    </div>
  </div>
<% end %>
