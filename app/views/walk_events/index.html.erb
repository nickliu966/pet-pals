<% content_for :title, "Walks" %>

<% nearby_results_frame_id = "walk_events_frame" %>

<% content_for :right_sidebar do %>
  <%= render "shared/nearby_filter", frame_id: nearby_results_frame_id %>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Walks</h1>

  <button type="button"
          class="btn btn-primary"
          data-bs-toggle="modal"
          data-bs-target="#createWalkModal">
    Create walk
  </button>
</div>

<div class="card mb-3">
  <div class="card-body">
    <%= search_form_for @q, url: walk_events_path, method: :get do |form| %>
      <div class="input-group">
        <%= form.search_field :title_or_note_or_location_name_cont,
              class: "form-control",
              placeholder: "Search walks by title, note, or location" %>

        <%= form.submit "Search", class: "btn btn-outline-primary" %>

        <% if params[:q].present? %>
          <%= link_to "Clear",
                walk_events_path,
                class: "btn btn-outline-secondary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%= turbo_frame_tag nearby_results_frame_id do %>
  <% if @walk_events.any? %>
    <%= render partial: "walk_events/walk_event",
          collection: @walk_events,
          as: :walk_event,
          locals: { render_edit_modal: false } %>
  <% else %>
    <p class="text-muted">
      No walks found.
    </p>
  <% end %>
<% end %>
