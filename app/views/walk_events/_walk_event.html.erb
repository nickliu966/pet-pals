<div id="<%= dom_id(walk_event) %>" class="p-3">
  <div class="d-flex justify-content-between align-items-start mb-2">
    <div>
      <h5 class="mb-1">
        <%= link_to walk_event.title, walk_event_path(walk_event), class: "text-decoration-none" %>
      </h5>

      <div class="text-muted">
        Hosted by
        <%= link_to walk_event.host_user.name, user_path(walk_event.host_user.username), class: "text-decoration-none" %>
        with
        <%= link_to walk_event.host_pet.name, pet_path(walk_event.host_pet), class: "text-decoration-none" %>
      </div>
    </div>

    <small class="text-muted">
      <%= walk_event.status %>
    </small>
  </div>

  <p class="mb-2">
    <%= walk_event.note %>
  </p>

  <div class="small text-muted mb-2">
    <i class="fa-solid fa-location-dot"></i>
    <%= walk_event.location_name %>
    ·
    <%= walk_event.start_time.strftime("%b %-d, %-I:%M %p") if walk_event.start_time.present? %>
    ·
    <%= walk_event.duration_minutes %> min
  </div>

  <div class="d-flex justify-content-between align-items-center">
    <%= link_to walk_event_path(walk_event),  class: "btn btn-link text-decoration-none p-0" do %>
      Participants: <%= walk_event.walk_participants.count %>
    <% end %>

    <% unless walk_event.host_user == current_user %>
      <%= link_to "View / Join", walk_event_path(walk_event), class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>
</div>
