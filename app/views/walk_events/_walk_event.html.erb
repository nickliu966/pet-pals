<% host_participants = walk_event.walk_participants.select { |participant| participant.user == walk_event.host_user } %>
<% host_pets = host_participants.map(&:pet).compact %>
<% show_view_button = local_assigns.fetch(:show_view_button, true) %>
<% render_edit_modal = local_assigns.fetch(:render_edit_modal, true) %>

<div id="<%= dom_id(walk_event) %>" class="card mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h4 class="mb-1">
          <%= link_to walk_event.title,
                walk_event_path(walk_event, return_to: request.fullpath),
                class: "text-decoration-none" %>
        </h4>

        <div class="mb-2">
          Hosted by
          <%= link_to walk_event.host_user.username,
                user_path(walk_event.host_user.username),
                class: "text-decoration-none" %>

          <% if host_pets.any? %>
            with
            <%= safe_join(
                  host_pets.map { |pet|
                    link_to pet.name,
                          pet_path(pet),
                          class: "text-decoration-none"
                  },
                  ", ".html_safe
                ) %>
          <% end %>
        </div>

        <% if walk_event.note.present? %>
          <p class="mb-2">
            <%= walk_event.note %>
          </p>
        <% end %>

        <div class="text-muted small mb-2">
          <% if walk_event.location_name.present? %>
            <i class="fa-solid fa-location-dot"></i>
            <%= walk_event.location_name %>
          <% end %>

          <% if walk_event.start_time.present? %>
            · <%= walk_event.start_time.strftime("%b %-d, %-I:%M %p") %>
          <% end %>

          <% if walk_event.duration_minutes.present? %>
            · <%= walk_event.duration_minutes %> min
          <% end %>
        </div>

        <%= link_to walk_event_path(walk_event, return_to: request.fullpath),
              class: "text-decoration-none" do %>
          <%= render "walk_events/participant_count", walk_event: walk_event %>
        <% end %>
      </div>

      <div class="text-end">
        <div class="text-muted mb-3">
          <%= walk_event.status %>
        </div>

        <% if allowed_to?(:edit?, walk_event) %>
          <div class="dropdown">
            <%= button_tag type: "button",
                  class: "btn btn-link text-decoration-none p-0",
                  data: {
                    bs_toggle: "dropdown",
                    bs_auto_close: "outside"
                  },
                  aria: { expanded: false } do %>
              <i class="fa-solid fa-ellipsis"></i>
            <% end %>

            <div class="dropdown-menu dropdown-menu-end p-0 walk-actions-menu">
              <% if render_edit_modal %>
                <button type="button"
                        class="dropdown-item py-2"
                        data-bs-toggle="modal"
                        data-bs-target="#<%= dom_id(walk_event, :form_modal) %>">
                  Edit
                </button>
              <% else %>
                <%= link_to "Edit",
                      edit_walk_event_path(walk_event, return_to: "#{request.fullpath}##{dom_id(walk_event)}"),
                      class: "dropdown-item py-2" %>
              <% end %>

              <div class="dropdown-divider m-0"></div>

              <div class="px-2 py-2 border-bottom">
                <%= form_with model: walk_event,
                      url: walk_event_path(walk_event),
                      method: :patch,
                      local: true do |form| %>

                  <%= hidden_field_tag :return_to, "#{request.fullpath}##{dom_id(walk_event)}" %>

                  <div class="d-flex align-items-center justify-content-between gap-1">
                    <span class="small fw-semibold text-muted">
                      Visibility
                    </span>

                    <%= form.select :visibility,
                          options_for_select(
                            [
                              ["Everyone", "everyone"],
                              ["Owner friends only", "user_friends_only"],
                              ["Pet friends only", "pet_friends_only"],
                              ["Friends of either", "friends_of_either"]
                            ],
                            walk_event.visibility
                          ),
                          {},
                          class: "form-select form-select-sm walk-visibility-select",
                          onchange: "this.form.requestSubmit()" %>
                  </div>
                <% end %>
              </div>

              <%= button_to "Delete",
                    walk_event_path(walk_event),
                    method: :delete,
                    class: "dropdown-item text-danger rounded-0 py-2" %>
            </div>
          </div>
        <% elsif show_view_button %>
          <%= link_to "View / Join",
                walk_event_path(walk_event, return_to: request.fullpath),
                class: "btn btn-sm btn-outline-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if render_edit_modal && allowed_to?(:edit?, walk_event) %>
  <% content_for :modals do %>
    <%= render "shared/form_modal",
          record: walk_event,
          modal_id: dom_id(walk_event, :form_modal),
          title: "Edit walk",
          form_partial: "walk_events/form",
          form_locals: {
            walk_event: walk_event,
            return_to: "#{request.fullpath}##{dom_id(walk_event)}",
            modal: true
          } %>
  <% end %>
<% end %>
