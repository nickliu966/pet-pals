<% back_path =
     if params[:return_to].present? && params[:return_to].start_with?("/")
       params[:return_to]
     else
       walk_events_path
     end %>

<div class="fs-5 border-bottom mb-3">
  <%= link_to back_path, class: "text-decoration-none" do %>
    ← Back
  <% end %>
</div>

<% content_for :right_sidebar do %>
  <% if allowed_to?(:invite_participant?, @walk_event) %>
    <% owner_friends = (current_user.owner_friends + current_user.friended_by_users).uniq %>

    <% already_invited_or_joined_user_ids =
         @walk_event.walk_participants
                    .where.not(status: "cancelled")
                    .pluck(:user_id) %>

    <% invitable_users =
         owner_friends.reject { |friend| already_invited_or_joined_user_ids.include?(friend.id) } %>

    <div class="card mt-3">
      <div class="card-body">
        <h5 class="card-title">Invite a friend</h5>

        <% if invitable_users.any? %>
          <%= form_with url: invite_participant_walk_event_path(@walk_event), method: :post do %>
            <div class="mb-2">
              <%= select_tag :user_id,
                    options_from_collection_for_select(invitable_users, :id, :username),
                    class: "form-select" %>
            </div>

            <%= submit_tag "Invite", class: "btn btn-outline-primary w-100" %>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">
            No available friends to invite.
          </p>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<%= render @walk_event, show_view_button: false %>

<% invitation = @walk_event.walk_participants.find_by(user: current_user, status: "invited") %>

<% if invitation.present? %>
  <div class="card mb-3">
    <div class="card-body">
      <h5 class="card-title">You were invited to this walk</h5>

      <p class="text-muted mb-3">
        Accept the invitation before appearing as a participant.
      </p>

      <div class="d-flex gap-2">
        <%= button_to "Accept",
              accept_walk_participant_path(invitation),
              method: :patch,
              class: "btn btn-primary" %>

        <%= button_to "Decline",
              decline_walk_participant_path(invitation),
              method: :patch,
              class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
<% end %>

<hr>

<h3>Joining people and pets</h3>

<% confirmed_participants = @walk_event.confirmed_participants.includes(:pet, :user) %>

<% if confirmed_participants.any? %>
  <ul class="list-group list-group-flush mb-3">
    <% confirmed_participants.each do |participant| %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <div>
          <strong>
            <%= link_to participant.user.username,
                  user_path(participant.user.username),
                  class: "text-decoration-none" %>
          </strong>

          <% if participant.pet.present? %>
            <span class="text-muted">with</span>

            <%= link_to participant.pet.name,
                  pet_path(participant.pet),
                  class: "text-decoration-none" %>
          <% else %>
            <span class="text-muted">
              joined without a pet
            </span>
          <% end %>

          <% if participant.user == @walk_event.host_user %>
            <span class="badge text-bg-secondary ms-2">Host</span>
          <% end %>

          <% if participant.user == current_user %>
            <span class="badge text-bg-primary ms-1">You</span>
          <% end %>
        </div>

        <% if participant.user == current_user || @walk_event.host_user == current_user %>
          <%= button_to "Remove",
                walk_participant_path(participant),
                method: :delete,
                class: "btn btn-sm btn-outline-danger" %>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-muted">
    No one has joined this walk yet.
  </p>
<% end %>

<% unless @walk_event.host_user == current_user %>
  <% current_user_participants = @walk_event.walk_participants.where(user: current_user) %>
  <% already_joined = current_user_participants.exists? %>
  <% eligible_pets = @walk_event.eligible_pets_for(current_user) %>

  <% if eligible_pets.any? || !already_joined %>
    <h3>Join this walk</h3>

    <%= form_with url: walk_participants_path, method: :post do %>
      <%= hidden_field_tag "walk_participant[walk_event_id]", @walk_event.id %>

      <% if params[:return_to].present? %>
        <%= hidden_field_tag :return_to, params[:return_to] %>
      <% end %>

      <% if eligible_pets.any? %>
        <div class="border rounded p-3 mb-3">
          <div class="form-label">
            Pets you are bringing
          </div>

          <% eligible_pets.each do |pet| %>
            <div class="form-check">
              <%= check_box_tag "walk_participant[pet_ids][]",
                    pet.id,
                    false,
                    id: "walk_participant_pet_ids_#{pet.id}",
                    class: "form-check-input" %>

              <%= label_tag "walk_participant_pet_ids_#{pet.id}",
                    pet.name,
                    class: "form-check-label" %>
            </div>
          <% end %>

          <div class="form-text">
            Optional. Leave all unchecked if you are joining without a pet.
          </div>
        </div>
      <% else %>
        <p class="text-muted">
          You can join this walk without bringing a pet.
        </p>
      <% end %>

      <%= submit_tag already_joined ? "Add selected pets" : "Join walk",
            class: "btn btn-primary" %>
    <% end %>
  <% else %>
    <p class="text-muted">
      You are already joining this walk.
    </p>
  <% end %>
<% end %>

<hr>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3 class="mb-0">Posts from this walk</h3>

  <% if @walk_event.involved_user?(current_user) %>
    <button type="button"
            class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#<%= dom_id(@walk_event, :post_form_modal) %>">
      Share post
    </button>
  <% end %>
</div>

<% if @walk_event.posts.any? %>
  <ul class="list-group list-group-flush">
    <%= render partial: "posts/post",
          collection: @walk_event.posts.default_order,
          layout: "layouts/list_group" %>
  </ul>
<% else %>
  <p class="text-muted">
    No posts from this walk yet.
  </p>
<% end %>

<% if @walk_event.involved_user?(current_user) %>
  <% content_for :modals do %>
    <%= render "shared/form_modal",
          record: Post.new,
          modal_id: dom_id(@walk_event, :post_form_modal),
          title: "Share post from this walk",
          form_partial: "posts/form",
          form_locals: {
            post: current_user.posts.build(walk_event: @walk_event),
            walk_event: @walk_event,
            return_to: walk_event_path(@walk_event),
            modal: true
          } %>
  <% end %>
<% end %>
