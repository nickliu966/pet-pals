<div class="fs-5 border-bottom mb-3">
  <%= link_to walk_events_path, class: "text-decoration-none" do %>
    ← Back to walks
  <% end %>
</div>

<%= render @walk_event %>

<hr>

<h3>Joining pets</h3>

<ul class="list-group list-group-flush mb-3">
  <% @walk_event.walk_participants.each do |participant| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <div>
        <%= link_to participant.pet.name, pet_path(participant.pet), class: "text-decoration-none" %>
        with
        <%= link_to participant.user.username, user_path(participant.user.username), class: "text-decoration-none" %>
      </div>

      <% if participant.user == current_user %>
        <%= button_to "Leave",
              walk_participant_path(participant),
              method: :delete,
              class: "btn btn-sm btn-outline-danger" %>
      <% end %>
    </li>
  <% end %>
</ul>

<% unless @walk_event.host_user == current_user %>
  <% eligible_pets = @walk_event.eligible_pets_for(current_user) %>

  <% if eligible_pets.any? %>
    <h4>Join this walk</h4>

    <% eligible_pets.each do |pet| %>
      <%= button_to "Join with #{pet.name}",
            walk_participants_path,
            method: :post,
            params: {
              walk_participant: {
                walk_event_id: @walk_event.id,
                pet_id: pet.id
              }
            },
            class: "btn btn-primary btn-sm mb-2" %>
    <% end %>
  <% else %>
    <p class="text-muted">
      You do not have an eligible pet for this walk.
    </p>
  <% end %>
<% end %>
