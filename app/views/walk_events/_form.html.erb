<%= form_with(model: walk_event) do |form| %>
  <% if walk_event.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(walk_event.errors.count, "error") %> prohibited this walk_event from being saved:</h2>

      <ul>
        <% walk_event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :host_user_id, style: "display: block" %>
    <%= form.number_field :host_user_id %>
  </div>

  <div>
    <%= form.label :host_pet_id, style: "display: block" %>
    <%= form.number_field :host_pet_id %>
  </div>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :note, style: "display: block" %>
    <%= form.textarea :note %>
  </div>

  <div>
    <%= form.label :location_name, style: "display: block" %>
    <%= form.text_field :location_name %>
  </div>

  <div>
    <%= form.label :latitude, style: "display: block" %>
    <%= form.text_field :latitude %>
  </div>

  <div>
    <%= form.label :longitude, style: "display: block" %>
    <%= form.text_field :longitude %>
  </div>

  <div>
    <%= form.label :start_time, style: "display: block" %>
    <%= form.datetime_field :start_time %>
  </div>

  <div>
    <%= form.label :duration_minutes, style: "display: block" %>
    <%= form.number_field :duration_minutes %>
  </div>

  <div>
    <%= form.label :visibility, style: "display: block" %>
    <%= form.number_field :visibility %>
  </div>

  <div>
    <%= form.label :max_participants, style: "display: block" %>
    <%= form.number_field :max_participants %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.number_field :status %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
