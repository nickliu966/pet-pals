<%= form_with(model: walk_event) do |form| %>
  <% if walk_event.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% walk_event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% selected_host_pet_ids =
       if walk_event.persisted?
         walk_event.walk_participants.where(user: walk_event.host_user).pluck(:pet_id)
       else
         []
       end %>

  <div class="form-group mb-2">
    <label class="form-label">Pets you are bringing</label>

    <div class="border rounded p-2">
      <% current_user.pets.each do |pet| %>
        <div class="form-check">
          <%= check_box_tag "walk_event[host_pet_ids][]",
                pet.id,
                selected_host_pet_ids.include?(pet.id),
                id: "walk_event_host_pet_ids_#{pet.id}",
                class: "form-check-input" %>

          <%= label_tag "walk_event_host_pet_ids_#{pet.id}",
                pet.name,
                class: "form-check-label" %>
        </div>
      <% end %>
    </div>

    <div class="form-text">
      Select one or more pets you plan to bring.
    </div>
  </div>

  <div class="form-group mb-2">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :note %>
    <%= form.text_area :note, class: "form-control" %>
  </div>

<div class="form-group mb-3"
     data-controller="google-search">
  <%= form.label :location_name, "Search location" %>

  <div class="form-control mb-2"
       data-google-search-target="searchBox">
  </div>

  <div data-google-search-target="map"
       class="border rounded mb-2"
       style="height: 240px;">
  </div>

  <%= form.text_field :location_name,
        class: "form-control",
        placeholder: "Selected location",
        data: { google_search_target: "locationName" } %>

  <%= form.hidden_field :latitude,
        data: { google_search_target: "latitude" } %>

  <%= form.hidden_field :longitude,
        data: { google_search_target: "longitude" } %>

  <%= form.hidden_field :google_place_id,
        data: { google_search_target: "placeId" } %>
</div>

  <div class="form-group mb-2">
    <%= form.label :start_time %>
    <%= form.datetime_field :start_time, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :duration_minutes %>
    <%= form.number_field :duration_minutes, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :visibility %>
    <%= form.select :visibility,
          options_for_select(
            WalkEvent.visibilities.keys.map { |visibility| [visibility.humanize, visibility] },
            walk_event.visibility
          ),
          {},
          class: "form-select" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :max_participants, "Max participants" %>
    <%= form.number_field :max_participants,
          class: "form-control",
          min: 1,
          placeholder: "Leave blank for no limit" %>
  </div>

  <div class="d-flex justify-content-end">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
