<%= form_with(model: walk_event) do |form| %>
  <% if walk_event.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% walk_event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group mb-2">
    <%= form.label :host_pet_id, "Host pet" %>
    <%= form.collection_select :host_pet_id,
          current_user.pets,
          :id,
          :name,
          {},
          class: "form-select" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :note %>
    <%= form.text_area :note, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :location_name, "Location" %>
    <%= form.select :location_name,
        options_for_select(WalkEvent.location_names, walk_event.location_name),
        { prompt: "Choose a walk location" },
        class: "form-select" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :start_time %>
    <%= form.datetime_field :start_time, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :duration_minutes %>
    <%= form.number_field :duration_minutes, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :visibility %>
    <%= form.text_field :visibility, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :max_participants %>
    <%= form.number_field :max_participants, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :status %>
    <%= form.text_field :status, class: "form-control" %>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
