<%= form_with(model: walk_event) do |form| %>
  <% if walk_event.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% walk_event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group mb-2">
    <%= form.label :host_pet_id, "Host pet" %>
    <%= form.collection_select :host_pet_id,
          current_user.pets,
          :id,
          :name,
          {},
          class: "form-select" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :note %>
    <%= form.text_area :note, class: "form-control" %>
  </div>

  <div data-controller="google-search">
    <div class="form-group mb-2">
      <%= form.label :location_name, "Search location" %>

      <div id="search-box-container" class="mb-2"></div>

      <div id="minimap" class="mb-2" style="height: 240px;"></div>

      <%= form.text_field :location_name,
          id: "walk_location_name_box",
          class: "form-control",
          placeholder: "Selected location" %>

      <%= form.hidden_field :latitude, id: "walk_latitude_box" %>
      <%= form.hidden_field :longitude, id: "walk_longitude_box" %>
    </div>
  </div>

  <div class="form-group mb-2">
    <%= form.label :start_time %>
    <%= form.datetime_field :start_time, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :duration_minutes %>
    <%= form.number_field :duration_minutes, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :visibility %>
    <%= form.select :visibility,
        options_for_select(
          WalkEvent.visibilities.keys.map { |visibility| [ visibility.humanize, visibility ] },
          walk_event.visibility
        ),
        {},
        class: "form-select" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :max_participants, "Max participants" %>
    <%= form.number_field :max_participants,
        class: "form-control",
        min: 1,
        placeholder: "Leave blank for no limit" %>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
