<%= form_with(model: pet) do |form| %>
  <% return_to = local_assigns[:return_to] %>
  <% modal = local_assigns.fetch(:modal, false) %>

  <% if return_to.present? %>
    <%= hidden_field_tag :return_to, return_to %>
  <% end %>

  <% if pet.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% pet.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group mb-2">
    <%= form.label :name %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :species %>
    <%= form.text_field :species, class: "form-control", placeholder: "Dog, cat, rabbit..." %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :breed %>
    <%= form.text_field :breed, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :gender %>
    <%= form.text_field :gender, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :birthday %>
    <%= form.date_field :birthday, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :size %>
    <%= form.text_field :size, class: "form-control", placeholder: "Small, medium, large..." %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :energy_level %>
    <%= form.text_field :energy_level, class: "form-control", placeholder: "Low, medium, high..." %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :temperament %>
    <%= form.text_field :temperament, class: "form-control", placeholder: "Friendly, shy, playful..." %>
  </div>

  <div class="form-check mb-2">
    <%= form.checkbox :vaccinated, class: "form-check-input" %>
    <%= form.label :vaccinated, class: "form-check-label" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :image_url, "Image URL" %>
    <%= form.text_field :image_url,
          class: "form-control",
          placeholder: "https://..." %>
  </div>

  <div class="form-group mb-3">
    <%= form.label :bio %>
    <%= form.text_area :bio,
          class: "form-control",
          rows: 3,
          placeholder: "Tell others about this pet..." %>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <% if modal %>
      <button type="button"
              class="btn btn-outline-secondary"
              data-bs-dismiss="modal">
        Cancel
      </button>
    <% elsif pet.persisted? %>
      <% cancel_path =
           if return_to.present? && return_to.start_with?("/")
             return_to
           else
             pet_path(pet)
           end %>

      <%= link_to "Cancel",
            cancel_path,
            class: "btn btn-outline-secondary" %>
    <% else %>
      <%= link_to "Cancel",
            user_pets_path(current_user.username),
            class: "btn btn-outline-secondary" %>
    <% end %>

    <%= form.submit pet.persisted? ? "Update pet" : "Create pet",
          class: "btn btn-primary" %>
  </div>
<% end %>
