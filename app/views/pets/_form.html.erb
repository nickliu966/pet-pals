<%= form_with(model: pet) do |form| %>
  <% return_to = local_assigns[:return_to] %>
  <% modal = local_assigns.fetch(:modal, false) %>

  <% if return_to.present? %>
    <%= hidden_field_tag :return_to, return_to %>
  <% end %>

  <% if pet.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% pet.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-section">
    <div class="form-section-title">Basic profile</div>
    <div class="form-section-subtitle">
      Add the information people see first on your pet’s profile.
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <%= form.label :name, class: "form-label fw-semibold" %>
        <%= form.text_field :name,
              class: "form-control",
              placeholder: "Mochi" %>
      </div>

      <div class="col-md-6">
        <%= form.label :species, class: "form-label fw-semibold" %>
        <%= form.text_field :species,
              class: "form-control",
              placeholder: "Dog, cat, rabbit..." %>
      </div>

      <div class="col-md-6">
        <%= form.label :breed, class: "form-label fw-semibold" %>
        <%= form.text_field :breed,
              class: "form-control",
              placeholder: "Golden retriever" %>
      </div>

      <div class="col-md-6">
        <%= form.label :gender, class: "form-label fw-semibold" %>
        <%= form.text_field :gender,
              class: "form-control",
              placeholder: "Female, male..." %>
      </div>

      <div class="col-md-6">
        <%= form.label :birthday, class: "form-label fw-semibold" %>
        <%= form.date_field :birthday,
              class: "form-control" %>
      </div>

      <div class="col-md-6">
        <%= form.label :image_url, "Image URL", class: "form-label fw-semibold" %>
        <%= form.text_field :image_url,
              class: "form-control",
              placeholder: "https://..." %>
      </div>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-title">Personality</div>
    <div class="form-section-subtitle">
      Help other owners understand whether this pet is a good match.
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <%= form.label :size, class: "form-label fw-semibold" %>
        <%= form.text_field :size,
              class: "form-control",
              placeholder: "Small, medium, large..." %>
      </div>

      <div class="col-md-6">
        <%= form.label :energy_level, class: "form-label fw-semibold" %>
        <%= form.text_field :energy_level,
              class: "form-control",
              placeholder: "Low, medium, high..." %>
      </div>

      <div class="col-12">
        <%= form.label :temperament, class: "form-label fw-semibold" %>
        <%= form.text_field :temperament,
              class: "form-control",
              placeholder: "Friendly, shy, playful..." %>
      </div>

      <div class="col-12">
        <div class="form-check p-3 rounded border bg-white">
          <%= form.checkbox :vaccinated, class: "form-check-input" %>
          <%= form.label :vaccinated, class: "form-check-label fw-semibold" %>
        </div>
      </div>

      <div class="col-12">
        <%= form.label :bio, class: "form-label fw-semibold" %>
        <%= form.text_area :bio,
              class: "form-control",
              rows: 3,
              placeholder: "Tell others about this pet..." %>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <% if modal %>
      <button type="button"
              class="btn btn-outline-secondary rounded-pill px-4"
              data-bs-dismiss="modal">
        Cancel
      </button>
    <% elsif pet.persisted? %>
      <% cancel_path =
           if return_to.present? && return_to.start_with?("/")
             return_to
           else
             pet_path(pet)
           end %>

      <%= link_to "Cancel",
            cancel_path,
            class: "btn btn-outline-secondary rounded-pill px-4" %>
    <% else %>
      <%= link_to "Cancel",
            user_pets_path(current_user.username),
            class: "btn btn-outline-secondary rounded-pill px-4" %>
    <% end %>

    <%= form.submit pet.persisted? ? "Update pet" : "Create pet",
          class: "btn btn-primary rounded-pill px-4" %>
  </div>
<% end %>
