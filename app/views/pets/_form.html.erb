<%= form_with(model: pet) do |form| %>
  <% if pet.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% pet.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group mb-2">
    <%= form.label :name %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :species %>
    <%= form.text_field :species, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :breed %>
    <%= form.text_field :breed, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :gender %>
    <%= form.text_field :gender, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :birthday %>
    <%= form.date_field :birthday, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :size %>
    <%= form.text_field :size, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :energy_level %>
    <%= form.text_field :energy_level, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :temperament %>
    <%= form.text_field :temperament, class: "form-control" %>
  </div>

  <div class="form-check mb-2">
    <%= form.checkbox :vaccinated, class: "form-check-input" %>
    <%= form.label :vaccinated, class: "form-check-label" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :image_url %>
    <%= form.text_field :image_url, class: "form-control" %>
  </div>

  <div class="form-group mb-2">
    <%= form.label :bio %>
    <%= form.text_area :bio, class: "form-control" %>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
