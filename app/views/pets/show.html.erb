<div class="fs-5 border-bottom mb-3">
  <%= link_to user_pets_path(@pet.user.username), class: "text-decoration-none" do %>
    ← Back to <%= @pet.user.username %>'s pets
  <% end %>
</div>

<div class="card mb-4 overflow-hidden">
  <% if @pet.image.attached? %>
    <%= image_tag @pet.image,
          class: "card-img-top",
          style: "height: 320px; object-fit: cover;",
          loading: "eager",
          decoding: "async" %>
  <% elsif @pet.image_url.present? %>
    <%= image_tag @pet.image_url,
          class: "card-img-top",
          style: "height: 320px; object-fit: cover;",
          loading: "eager",
          decoding: "async" %>
  <% end %>

  <div class="card-body p-4">
    <div class="d-flex justify-content-between align-items-start gap-3">
      <div class="min-width-0">
        <div class="page-kicker mb-1">
          Pet profile
        </div>

        <h1 class="card-title page-title mb-1">
          <%= @pet.name %>
        </h1>

        <p class="text-muted mb-3">
          Owned by
          <%= link_to @pet.user.username,
                user_path(@pet.user.username),
                class: "text-decoration-none fw-semibold" %>
        </p>

        <div class="row g-2 mb-3">
          <div class="col-6">
            <div class="small text-muted">Species</div>
            <div class="fw-semibold"><%= @pet.species.presence || "Unknown" %></div>
          </div>

          <div class="col-6">
            <div class="small text-muted">Breed</div>
            <div class="fw-semibold"><%= @pet.breed.presence || "Unknown" %></div>
          </div>

          <div class="col-6">
            <div class="small text-muted">Gender</div>
            <div class="fw-semibold"><%= @pet.gender.presence || "Unknown" %></div>
          </div>

          <div class="col-6">
            <div class="small text-muted">Size</div>
            <div class="fw-semibold"><%= @pet.size.presence || "Unknown" %></div>
          </div>

          <div class="col-6">
            <div class="small text-muted">Energy</div>
            <div class="fw-semibold"><%= @pet.energy_level.presence || "Unknown" %></div>
          </div>

          <div class="col-6">
            <div class="small text-muted">Vaccinated</div>
            <div class="fw-semibold"><%= @pet.vaccinated? ? "Yes" : "No" %></div>
          </div>
        </div>

        <% if @pet.temperament.present? %>
          <p class="mb-2">
            <strong>Temperament:</strong>
            <%= @pet.temperament %>
          </p>
        <% end %>

        <% if @pet.bio.present? %>
          <p class="mb-0 text-muted">
            <%= @pet.bio %>
          </p>
        <% end %>
      </div>

      <div class="flex-shrink-0">
        <% if allowed_to?(:edit?, @pet) %>
          <div class="dropdown">
            <%= button_tag class: "btn btn-link text-decoration-none",
                  data: { bs_toggle: "dropdown", bs_boundary: "viewport" },
                  aria: { expanded: false, label: "Pet actions" } do %>
              <i class="fa-solid fa-ellipsis"></i>
            <% end %>

            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <button type="button"
                        class="dropdown-item"
                        data-bs-toggle="modal"
                        data-bs-target="#<%= dom_id(@pet, :form_modal) %>">
                  Edit
                </button>
              </li>

              <li>
                <%= button_to pet_path(@pet),
                      method: :delete,
                      class: "dropdown-item text-danger" do %>
                  Delete
                <% end %>
              </li>
            </ul>
          </div>
        <% else %>
          <%= render "pet_friendships/pet_friend_button", pet: @pet %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<section class="mb-4">
  <div class="d-flex justify-content-between align-items-end mb-3">
    <div>
      <div class="page-kicker mb-1">
        Moments
      </div>

      <h2 class="h3 mb-0">
        Posts with <%= @pet.name %>
      </h2>
    </div>
  </div>

  <% pet_posts = @pet.posts.default_order %>

  <% if pet_posts.any? %>
    <ul class="list-group list-group-flush mb-4">
      <%= render partial: "posts/post",
            collection: pet_posts,
            layout: "layouts/list_group",
            locals: { render_edit_modal: false } %>
    </ul>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-icon mx-auto mb-3">
        <i class="fa-regular fa-images"></i>
      </div>

      <h3 class="h5">
        No posts yet
      </h3>

      <p class="text-muted mb-0">
        Posts featuring <%= @pet.name %> will appear here.
      </p>
    </div>
  <% end %>
</section>

<section>
  <div class="page-kicker mb-1">
    Walks
  </div>

  <h2 class="h3 mb-3">
    Walks hosted by <%= @pet.name %>
  </h2>

  <% if @pet.hosted_walk_events.any? %>
    <ul class="list-group list-group-flush">
      <%= render partial: "walk_events/walk_event",
            collection: @pet.hosted_walk_events,
            layout: "layouts/list_group" %>
    </ul>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-icon mx-auto mb-3">
        <i class="fa-solid fa-person-walking"></i>
      </div>

      <h3 class="h5">
        No hosted walks yet
      </h3>

      <p class="text-muted mb-0">
        Walks hosted by <%= @pet.name %> will appear here.
      </p>
    </div>
  <% end %>
</section>

<% if allowed_to?(:edit?, @pet) %>
  <% content_for :modals do %>
    <%= render "shared/form_modal",
          record: @pet,
          modal_id: dom_id(@pet, :form_modal),
          title: "Edit pet",
          form_partial: "pets/form",
          form_locals: {
            pet: @pet,
            return_to: request.fullpath,
            modal: true
          } %>
  <% end %>
<% end %>
