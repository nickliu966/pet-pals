<% content_for :title, "Pets" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Pets</h1>

  <button type="button"
        class="btn btn-primary"
        data-bs-toggle="modal"
        data-bs-target="#addPetModal">
    New pet
  </button>
</div>

<ul id="pets" class="list-group list-group-flush">
  <%= render partial: "pets/pet", collection: @pets, layout: "layouts/list_group" %>
</ul>
