<% content_for :title, "Editing pet" %>

<div class="card">
  <div class="card-header">
    Editing pet
  </div>

  <div class="card-body">
    <%= render "form", pet: @pet %>
  </div>
</div>

<div class="mt-3 d-flex gap-2">
  <%= link_to "Show this pet", @pet, class: "btn btn-outline-secondary" %>
  <%= link_to "Back to pet",
    pet_path(@pet),
    class: "btn btn-outline-secondary" %>
</div>
