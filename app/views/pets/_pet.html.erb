<div id="<%= dom_id(pet) %>" class="card">
  <% if pet.image_url.present? %>
    <%= image_tag pet.image_url,
        class: "card-img-top",
        style: "height: 320px; object-fit: cover;" %>
  <% end %>

  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h5 class="card-title mb-1">
          <%= link_to pet.name, pet_path(pet), class: "text-decoration-none" %>
        </h5>

        <p class="text-muted mb-2">
          Owned by <%= link_to pet.user.name, user_path(pet.user), class: "text-decoration-none" %>
        </p>
      </div>
    </div>

    <% if pet.respond_to?(:bio) && pet.bio.present? %>
      <p class="card-text">
        <%= pet.bio %>
      </p>
    <% end %>

    <div class="d-flex gap-3">
      <%= link_to "View profile", pet_path(pet), class: "btn btn-link text-decoration-none p-0" %>
    </div>
  </div>
</div>
